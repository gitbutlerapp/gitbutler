{
	"compilerOptions": {
		"target": "esnext",
		"module": "esnext",
		"moduleResolution": "bundler",
		"allowJs": true,
		"checkJs": true,
		"noEmit": true,
		"skipLibCheck": true,
		"esModuleInterop": true
	},
	"include": ["**/*.js", "**/*.mjs"],
	"exclude": [
		"**/.svelte-kit/",
		"**/build/",
		"**/dist/",
		"**/node_modules/",
		"**/target/",
		"packages/but-sdk/**/"
	]
}
