{
	"compilerOptions": {
		"target": "ES2022",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"strict": true,
		"noUncheckedIndexedAccess": true,
		"noImplicitReturns": true,
		"sourceMap": true,
		"outDir": "../dist/electron",
		"rootDir": "./src",
		"verbatimModuleSyntax": false,
		"types": ["node"],
		"skipLibCheck": true
	},
	"include": ["src"]
}
