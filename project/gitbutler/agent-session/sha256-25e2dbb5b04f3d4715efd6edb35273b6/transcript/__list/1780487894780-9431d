eview_id)\n+    }\n+\n+    pub fn details(&self) -> anyhow::Result<StackDetails> {\n+        let topmost_branch = self\n+            .branches\n+            .first()\n+            .context(\"Stacks should never be empty\")?;\n+        Ok(StackDetails {\n+            derived_name: topmost_branch.name.clone(),\n+            push_status: topmost_branch.details.push_status,\n+            is_conflicted: topmost_branch.details.is_conflicted,\n+            branch_details: self\n+                .branches\n+                .iter()\n+                .map(|branch| branch.details.clone())\n+                .collect(),\n+        })\n+    }\n+}\n+\n+pub fn head_info(ctx: &Context) -> anyhow::Result<RefInfo> {\n+    but_api::legacy::workspace::head_info(ctx)\n+}\n+\n+pub fn applied_stacks(ctx: &Context) -> anyhow::Result<Vec<HeadInfoStack>> {\n+    head_info(ctx)?\n+        .stacks\n+        .iter()\n+        .map(head_info_stack)\n+        .collect()\n+}\n+\n+pub fn stack_details_by_id(\n+    ctx: &Context,\n+    stack_id: Option<StackId>,\n+) -> anyhow::Result<StackDetails> {\n+    let stacks = applied_stacks(ctx)?;\n+    let stack = match stack_id {\n+        Some(stack_id) => stacks\n+            .iter()\n+            .find(|stack| stack.id == Some(stack_id))\n+            .with_context(|| format!(\"Stack {stack_id} not found in workspace\"))?,\n+        None => stacks\n+            .first()\n+            .context(\"Expected at least one stack in workspace\")?,\n+    };\n+    stack.details()\n+}\n+\n+pub fn stack_details_for_stack(stack: &HeadInfoStack) -> anyhow::Result<StackDetails> {\n+    stack.details()\n+}\n+\n+fn head_info_stack(stack: &branch::Stack) -> anyhow::Result<HeadInfoStack> {\n+    let branches = stack.segments.iter().map(head_info_branch).collect::<Result<Vec<_>, _>>()?;\n+    Ok(HeadInfoStack {\n+        id: stack.id,\n+        base: stack.base,\n+        branches,\n+    })\n+}\n+\n+fn head_info_branch(segment: &Segment) -> anyhow::Result<HeadInfoBranch> {\n+    let details = branch_details_from_segment(segment)?;\n+    Ok(HeadInfoBranch {\n+        name: details.name.to_string(),\n+        tip: details.tip,\n+        review_id: details\n+            .review_id\n+            .as_deref()\n+            .and_then(|review_id| review_id.parse().ok()),\n+        details,\n+    })\n+}\n+\n+fn branch_details_from_segment(\n+    Segment {\n+        id: _,\n+        ref_info,\n+        commits: local_commits,\n+        commits_on_remote,\n+        remote_tracking_ref_name,\n+        remote_tracking_branch_segment_id: _,\n+        commits_outside,\n+        metadata,\n+        push_status,\n+        is_entrypoint: _,\n+        base,\n+    }: &Segment,\n+) -> anyhow::Result<BranchDetails> {\n+    let ref_info = ref_info\n+        .clone()\n+        .context(\"Can't handle a stack yet whose tip isn't pointed to by a ref\")?;\n+    if let Some(commits_outside) = commits_outside.as_ref().filter(|commits| !commits.is_empty()) {\n+        tracing::warn!(\n+            ignored_outside_commits = commits_outside.len(),\n+            stack_segment_ref = %ref_info.ref_name,\n+            \"CLI head_info stack details drops commits_outside for this stack segment\"\n+        );\n+    }\n+    let (updated_at, review_id, pr_number) = metadata\n+        .clone()\n+        .map(|meta| {\n+            (\n+                meta.ref_info.updated_at,\n+                meta.review.review_id,\n+                meta.review.pull_request,\n+            )\n+        })\n+        .unwrap_or_default();\n+    let base_commit = base.unwrap_or(gix::hash::Kind::Sha1.null());\n+    let commits: Vec<ui::Commit> = local_commits.iter().map(Into::into).collect();\n+    let is_conflicted = local_commits\n+        .iter()\n+        .any(|commit| commit.inner.has_conflicts);\n+    Ok(BranchDetails {\n+        is_remote_head: ref_info\n+            .ref_name\n+            .category()\n+            .is_some_and(|category| matches!(category, gix::refs::Category::RemoteBranch)),\n+        name: ref_info.ref_name.shorten().into(),\n+        reference: ref_info.ref_name,\n+        linked_worktree_id: ref_info.worktree.and_then(|ws| match ws.kind {\n+            but_graph::WorktreeKind::Main => None,\n+            but_graph::WorktreeKind::LinkedId(id) => Some(id),\n+        }),\n+        remote_tracking_branch: remote_tracking_ref_name\n+            .as_ref()\n+            .map(|full_name| full_name.as_bstr().into()),\n+        pr_number,\n+        review_id,\n+        tip: local_commits\n+            .first()\n+            .map(|commit| commit.id)\n+            .unwrap_or(base_commit),\n+        base_commit,\n+        push_status: *push_status,\n+        last_updated_at: updated_at.map(|time| time.seconds as i128 * 1_000),\n+        authors: authors(local_commits, commits_on_remote),\n+        is_conflicted,\n+        commits,\n+        upstream_commits: commits_on_remote.iter().map(Into::into).collect(),\n+        is_remote_head: false,\n+    })\n+}\n+\n+fn authors(\n+    local_commits: &[but_workspace::ref_info::LocalCommit],\n+    commits_on_remote: &[but_workspace::ref_info::Commit],\n+) -> Vec<ui::Author> {\n+    let mut authors = HashSet::<ui::Author>::new();\n+    let all_commits = local_commits\n+        .iter()\n+        .map(|commit| &commit.inner)\n+        .chain(commits_on_remote.iter());\n+    for commit in all_commits {\n+        authors.insert((commit.author.to_ref(&mut TimeBuf::default())).into());\n+    }\n+    let mut authors: Vec<_> = authors.into_iter().collect();\n+    authors.sort_by(|a, b| a.name.cmp(&b.name));\n+    authors\n+}\n*** End Patch\n","source_record":{"timestamp":"2026-06-03T11:52:22.598Z","type":"response_item","payload":{"type":"custom_tool_call","status":"completed","call_id":"[REDACTED:entropy]","name":"apply_patch"}}}