zed subcommand 'no-such-command'\n\nUsage: but [OPTIONS] [COMMAND]\n\nFor more information, try '--help'.\n\n\"#]]);\n\n    Ok(())\n}\n\n#[test]\n/// We want the output of `help --help` to be the same as `help`.\nfn help_help_should_be_help() -> anyhow::Result<()> {\n    let env = Sandbox::empty()?;\n\n    let help = env.but(\"help\").output()?.stdout;\n","tool_name":"exec_command","tool_kind":"exec","tool_input":null,"exit_code":0,"outcome":"succeeded","source_record":{"timestamp":"2026-05-29T16:14:47.665Z","type":"response_item","payload":{"type":"function_call_output","call_id":"[REDACTED:entropy]"}}}