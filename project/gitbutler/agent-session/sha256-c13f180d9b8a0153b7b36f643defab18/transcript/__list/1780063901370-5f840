::worktree(\n            ctx,\n            out,\n            StatusFlags {\n                show_files: crate::command::legacy::status::FilesStatusFlag::All,\n","tool_name":"exec_command","tool_kind":"exec","tool_input":null,"exit_code":0,"outcome":"succeeded","source_record":{"timestamp":"2026-05-29T14:07:31.571Z","type":"response_item","payload":{"type":"function_call_output","call_id":"[REDACTED:entropy]"}}}