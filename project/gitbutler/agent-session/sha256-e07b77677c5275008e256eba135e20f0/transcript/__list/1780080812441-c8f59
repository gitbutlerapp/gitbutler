ild\n# — with a single group kill, which also works if an intermediate parent has\n# already exited (a plain per-PID kill would orphan the reparented children).\nset -m\n\nbackend_pid=\"\"\nfrontend_pid=\"\"\ncleanup() {\n  trap - EXIT INT TERM\n  [ -n \"$frontend_pid\" ] && kill -- -\"$frontend_pid\" 2>/dev/null || true\n  [ -n \"$backend_pid\" ]  && kill -- -\"$backend_pid\"  2>/dev/null || true\n}\ntrap cleanup EXIT INT TERM\n\necho \"[dev] starting backend (cargo run) on http://127.0.0.1:3000 ...\"\necho \"[dev] first compile can take a minute; the API 502s until it's ready.\"\ncargo run &\nbackend_pid=$!\n\necho \"[dev] starting Vite dev server - open http://127.0.0.1:5173/\"\nnpm --prefix web run dev &\nfrontend_pid=$!\n\nchild_status() {\n  set +e\n  wait \"$1\"\n  local status=$?\n  set -e\n  echo \"$status\"\n}\n\nwhile true; do\n  if ! kill -0 \"$backend_pid\" 2>/dev/null; then\n    status=\"$(child_status \"$backend_pid\")\"\n    echo \"[dev] backend exited with status $status; stopping Vite.\"\n    cleanup\n    exit \"$status\"\n  fi\n\n  if ! kill -0 \"$frontend_pid\" 2>/dev/null; then\n    status=\"$(child_status \"$frontend_pid\")\"\n    echo \"[dev] Vite exited with status $status; stopping backend.\"\n    cleanup\n    exit \"$status\"\n  fi\n\n  sleep 1\ndone\n","tool_name":"exec_command","tool_kind":"exec","tool_input":null,"exit_code":0,"outcome":"succeeded","source_record":{"timestamp":"2026-05-29T18:52:01.810Z","type":"response_item","payload":{"type":"function_call_output","call_id":"[REDACTED:entropy]"}}}