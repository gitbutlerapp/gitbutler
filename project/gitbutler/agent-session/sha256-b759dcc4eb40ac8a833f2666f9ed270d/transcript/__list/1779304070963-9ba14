{"source_key":"sha256-a74ceb5e1c9633ab993c14c11d587d71","record_index":154,"record_hash":"sha256:881791e4a64bde838d8ad0a4d3e0e547a5eae62bac4472df70c30f5c143f6ea2","timestamp":"2026-05-20T19:05:50.955Z","kind":"tool_call","source_event_kind":"codex:response_item:custom_tool_call","role":null,"text":null,"tool_name":"apply_patch","tool_input":"*** Begin Patch\n*** Add File: /Users/kiril/src/gitbutler/crates/but-agentlog/src/gitmeta/session_outline.rs\n+use std::collections::{BTreeSet, HashMap};\n+\n+use anyhow::{Context as _, Result, bail};\n+use chrono::{DateTime, Utc};\n+use git_meta_lib::{ListEntry, MetaValue, SessionTargetHandle};\n+use serde::Serialize;\n+use serde_json::Value;\n+\n+use super::{\n+    SessionListEntry, StoredObservedTargets, StoredTurnDetail, StoredTurnSummary,\n+    stored_turn_summary_entries,\n+};\n+\n+const PREVIEW_TEXT_CHARS: usize = 240;\n+\n+#[derive(Debug, Clone, PartialEq, Eq, Serialize)]\n+pub struct RelatedSession {\n+    pub session_key: String,\n+    pub updated_at: String,\n+    pub started_at: Option<String>,\n+    pub turn_count: usize,\n+    pub record_count: usize,\n+    pub latest_turn_key: Option<String>,\n+    pub latest_captured_at: Option<String>,\n+    pub related_turn_keys: Vec<String>,\n+    pub match_evidence: MatchEvidence,\n+    pub observed_targets: ObservedTargetKeys,\n+    pub source_keys: Vec<String>,\n+    pub sources: Vec<SessionSource>,\n+    pub agents: Vec<String>,\n+    pub providers: Vec<String>,\n+    pub models: Vec<String>,\n+    pub tool_versions: Vec<String>,\n+    pub latest_user_preview: Option<RecordPreview>,\n+    pub latest_assistant_preview: Option<RecordPreview>,\n+}\n+\n+#[derive(Debug, Clone, PartialEq, Eq, Serialize)]\n+pub struct MatchEvidence {\n+    pub matched_by: &'static str,\n+    pub matched_turn_keys: Vec<String>,\n+}\n+\n+#[derive(Debug, Clone, Default, PartialEq, Eq, Serialize)]\n+pub struct ObservedTargetKeys {\n+    pub branches: Vec<String>,\n+    pub reviews: Vec<String>,\n+    pub changes: Vec<String>,\n+}\n+\n+#[derive(Debug, Clone, PartialEq, Eq, Serialize)]\n+pub struct SessionSource {\n+    pub source_key: String,\n+    pub agent: Option<String>,\n+    pub provider: Option<String>,\n+    pub model: Option<String>,\n+    pub tool_version: Option<String>,\n+}\n+\n+#[derive(Debug, Clone, PartialEq, Eq, Serialize)]\n+pub struct RecordPreview {\n+    pub turn_key: Option<String>,\n+    pub record_hash: String,\n+    pub timestamp: Option<String>,\n+    pub source_event_kind: Option<String>,\n+    pub text: String,\n+}\n+\n+pub(super) struct RelatedSessionOutline {\n+    pub(super) session: RelatedSession,\n+    pub(super) sort_updated_at: DateTime<Utc>,\n+}\n+\n+pub(super) fn related_session_outline(\n+    handle: &SessionTargetHandle<'_>,\n+    entry: SessionListEntry,\n+    matched_by: &'static str,\n+    related_turn_keys: Vec<String>,\n+) -> Result<RelatedSessionOutline> {\n+    let session_prefix = format!(\"gitbutler:agent-session:{}\", entry.session_key);\n+    let source_keys = read_session_source_keys(handle, &session_prefix, &entry.session_key)?;\n+    let sources = read_session_sources(handle, &session_prefix, &source_keys)?;\n+    let summaries = read_turn_summaries(handle, &format!(\"{session_prefix}:turns\"))?;\n+    let mut record_count = 0;\n+    let mut hash_turns = HashMap::new();\n+    let mut observed_targets = ObservedTargetSets::default();\n+    for summary in &summaries {\n+        let detail = read_turn_detail(handle, &session_prefix, &summary.turn_key)?;\n+        record_count += detail.records.len();\n+        observed_targets.extend(&detail.observed_targets);\n+        for record in detail.records {\n+            hash_turns.insert(record.record_hash, summary.turn_key.clone());\n+        }\n+    }\n+\n+    let previews = session_previews(handle, &session_prefix, &hash_turns)?;\n+    let latest = summaries.last();\n+    let sources_index = SourceMetadataIndex::from_sources(&sources);\n+    Ok(RelatedSessionOutline {\n+        sort_updated_at: entry.sort_updated_at,\n+        session: RelatedSession {\n+            session_key: entry.session_key,\n+            updated_at: entry.updated_at,\n+            started_at: summaries.first().map(|summary| summary.captured_at.clone()),\n+            turn_count: summaries.len(),\n+            record_count,\n+            latest_turn_key: latest.map(|summary| summary.turn_key.clone()),\n+            latest_captured_at: latest.map(|summary| summary.captured_at.clone()),\n+            match_evidence: MatchEvidence {\n+                matched_by,\n+                matched_turn_keys: related_turn_keys.clone(),\n+            },\n+            related_turn_keys,\n+            observed_targets: observed_targets.into_keys(),\n+            source_keys,\n+            sources,\n+            agents: sources_index.agents,\n+            providers: sources_index.providers,\n+            models: sources_index.models,\n+            tool_versions: sources_index.tool_versions,\n+            latest_user_preview: previews.latest_user,\n+            latest_assistant_preview: previews.latest_assistant,\n+        },\n+    })\n+}\n+\n+fn read_turn_summaries(\n+    handle: &SessionTargetHandle<'_>,\n+    turns_key: &str,\n+) -> Result<Vec<StoredTurnSummary>> {\n+    let Some(turns_value) = handle\n+        .get_value(turns_key)\n+        .with_context(|| format!(\"failed to read GitMeta key '{turns_key}'\"))?\n+    else {\n+        return Ok(Vec::new());\n+    };\n+    let MetaValue::List(turn_entries) = turns_value else {\n+        bail!(\"existing GitMeta key '{turns_key}' is not a list\");\n+    };\n+\n+    Ok(stored_turn_summary_entries(turn_entries, turns_key)?\n+        .into_iter()\n+        .map(|entry| entry.summary)\n+        .collect())\n+}\n+\n+fn read_session_source_keys(\n+    handle: &SessionTargetHandle<'_>,\n+    session_prefix: &str,\n+    session_key: &str,\n+) -> Result<Vec<String>> {\n+    let sources_key = format!(\"{session_prefix}:sources\");\n+    let mut source_keys: Vec<String> = match handle\n+        .get_value(&sources_key)\n+        .with_context(|| format!(\"failed to read GitMeta key '{sources_key}'\"))?\n+    {\n+        None => bail!(\"existing session '{session_key}' is missing sources\"),\n+        Some(MetaValue::Set(source_keys)) => source_keys.into_iter().collect(),\n+        Some(_) => bail!(\"existing GitMeta key '{sources_key}' is not a set\"),\n+    };\n+    source_keys.sort();\n+    Ok(source_keys)\n+}\n+\n+fn read_session_sources(\n+    handle: &SessionTargetHandle<'_>,\n+    session_prefix: &str,\n+    source_keys: &[String],\n+) -> Result<Vec<SessionSource>> {\n+    source_keys\n+        .iter()\n+        .map(|source_key| {\n+            let source_prefix = format!(\"{session_prefix}:source:{source_key}\");\n+            Ok(SessionSource {\n+                source_key: source_key.clone(),\n+                agent: optional_string(handle, &format!(\"{source_prefix}:agent\"))?,\n+                provider: optional_string(handle, &format!(\"{source_prefix}:provider\"))?,\n+                model: optional_string(handle, &format!(\"{source_prefix}:model\"))?,\n+                tool_version: optional_string(handle, &format!(\"{source_prefix}:tool-version\"))?,\n+            })\n+        })\n+        .collect()\n+}\n+\n+fn optional_string(handle: &SessionTargetHandle<'_>, key: &str) -> Result<Option<String>> {\n+    match handle\n+        .get_value(key)\n+        .with_context(|| format!(\"failed to read GitMeta key '{key}'\"))?\n+    {\n+        None => Ok(None),\n+        Some(MetaValue::String(value)) => Ok(Some(value)),\n+        Some(_) => bail!(\"existing GitMeta key '{key}' is not a string\"),\n+    }\n+}\n+\n+#[derive(Default)]\n+struct SourceMetadataIndex {\n+    agents: Vec<String>,\n+    providers: Vec<String>,\n+    models: Vec<String>,\n+    tool_versions: Vec<String>,\n+}\n+\n+impl SourceMetadataIndex {\n+    fn from_sources(sources: &[SessionSource]) -> Self {\n+        let mut index = Self::default();\n+        for source in sources {\n+            push_unique(&mut index.agents, source.agent.as_deref());\n+            push_unique(&mut index.providers, source.provider.as_deref());\n+            push_unique(&mut index.models, source.model.as_deref());\n+            push_unique(&mut index.tool_versions, source.tool_version.as_deref());\n+        }\n+        index\n+    }\n+}\n+\n+fn push_unique(values: &mut Vec<String>, value: Option<&str>) {\n+    let Some(value) = value else {\n+        return;\n+    };\n+    if !values.iter().any(|existing| existing == value) {\n+        values.push(value.to_owned());\n+    }\n+}\n+\n+#[derive(Default)]\n+struct ObservedTargetSets {\n+    branches: BTreeSet<String>,\n+    reviews: BTreeSet<String>,\n+    changes: BTreeSet<String>,\n+}\n+\n+impl ObservedTargetSets {\n+    fn extend(&mut self, targets: &StoredObservedTargets) {\n+        self.branches\n+            .extend(targets.branches.iter().map(|target| target.key.clone()));\n+        self.reviews\n+            .extend(targets.reviews.iter().map(|target| target.key.clone()));\n+        self.changes\n+            .extend(targets.changes.iter().map(|target| target.key.clone()));\n+    }\n+\n+    fn into_keys(self) -> ObservedTargetKeys {\n+        ObservedTargetKeys {\n+            branches: self.branches.into_iter().collect(),\n+            reviews: self.reviews.into_iter().collect(),\n+            changes: self.changes.into_iter().collect(),\n+        }\n+    }\n+}\n+\n+#[derive(Default)]\n+struct SessionPreviews {\n+    latest_user: Option<RecordPreview>,\n+    latest_assistant: Option<RecordPreview>,\n+}\n+\n+fn session_previews(\n+    handle: &SessionTargetHandle<'_>,\n+    session_prefix: &str,\n+    hash_turns: &HashMap<String, String>,\n+) -> Result<SessionPreviews> {\n+    let transcript_key = format!(\"{session_prefix}:transcript\");\n+    let Some(value) = handle\n+        .get_value(&transcript_key)\n+        .with_context(|| format!(\"failed to read GitMeta key '{transcript_key}'\"))?\n+    else {\n+        return Ok(SessionPreviews::default());\n+    };\n+    let MetaValue::List(entries) = value else {\n+        bail!(\"existing GitMeta key '{transcript_key}' is not a list\");\n+    };\n+\n+    let mut previews = SessionPreviews::default();\n+    for entry in entries {\n+        let Ok(record) = serde_json::from_str::<Value>(&entry.value) else {\n+            continue;\n+        };\n+        if record[\"kind\"].as_str() != Some(\"message\") {\n+            continue;\n+        }\n+        let Some(text) = record[\"text\"].as_str().filter(|text| !text.trim().is_empty()) else {\n+            continue;\n+        };\n+        let Some(record_hash) = record[\"record_hash\"].as_str() else {\n+            continue;\n+        };\n+        let preview = RecordPreview {\n+            turn_key: hash_turns.get(record_hash).cloned(),\n+            record_hash: record_hash.to_owned(),\n+            timestamp: record[\"timestamp\"].as_str().map(ToOwned::to_owned),\n+            source_event_kind: record[\"source_event_kind\"].as_str().map(ToOwned::to_owned),\n+            text: compact_preview(text),\n+        };\n+        match record[\"role\"].as_str() {\n+            Some(\"user\") => previews.latest_user = Some(preview),\n+            Some(\"assistant\") => previews.latest_assistant = Some(preview),\n+            _ => {}\n+        }\n+    }\n+\n+    Ok(previews)\n+}\n+\n+fn compact_preview(text: &str) -> String {\n+    let trimmed = text.trim();\n+    let mut preview = trimmed.chars().take(PREVIEW_TEXT_CHARS).collect::<String>();\n+    if trimmed.chars().count() > PREVIEW_TEXT_CHARS {\n+        preview.push_str(\"...\");\n+    }\n+    preview\n+}\n+\n+fn read_turn_detail(\n+    handle: &SessionTargetHandle<'_>,\n+    session_prefix: &str,\n+    turn_key: &str,\n+) -> Result<StoredTurnDetail> {\n+    let detail_key = format!(\"{session_prefix}:turn:{turn_key}\");\n+    let Some(value) = handle\n+        .get_value(&detail_key)\n+        .with_context(|| format!(\"failed to read GitMeta key '{detail_key}'\"))?\n+    else {\n+        bail!(\"existing GitMeta key '{detail_key}' is missing\");\n+    };\n+    let MetaValue::String(detail) = value else {\n+        bail!(\"existing GitMeta key '{detail_key}' is not a string\");\n+    };\n+    serde_json::from_str(&detail)\n+        .with_context(|| format!(\"existing GitMeta key '{detail_key}' has invalid JSON\"))\n+}\n*** End Patch\n","source_record":{"timestamp":"2026-05-20T19:05:50.955Z","type":"response_item","payload":{"type":"custom_tool_call","status":"completed","call_id":"[REDACTED:entropy]","name":"apply_patch"}}}