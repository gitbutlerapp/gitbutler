_preview: Option<RecordPreview>,\n+    pub tool_counts: ToolCounts,\n+}\n+\n+#[derive(Debug, Clone, PartialEq, Eq, Serialize)]\n+pub struct RecordIndexRange {\n+    pub start: Option<usize>,\n+    pub end: Option<usize>,\n+}\n+\n+#[derive(Debug, Clone, Default, PartialEq, Eq, Serialize)]\n+pub struct ToolCounts {\n+    pub tool_call_count: usize,\n+    pub tool_result_count: usize,\n+    pub command_count: usize,\n+    pub tool_names: Vec<String>,\n+}\n+\n+pub fn get_session_timeline_outline(\n+    repo_path: &std::path::Path,\n+    session_key: &str,\n+    max_turns: Option<usize>,\n+) -> Result<SessionTimeline> {\n+    with_project_target(repo_path, |handle| {\n+        let session_prefix = format!(\"gitbutler:agent-session:{session_key}\");\n+        let turns_key = format!(\"{session_prefix}:turns\");\n+        let summaries = read_turn_summaries(handle, &turns_key, None)?;\n+        let total_turns = summaries.len();\n+        let start = max_turns\n+            .and_then(|max_turns| total_turns.checked_sub(max_turns))\n+            .unwrap_or(0);\n+        let selected = summaries\n+            .into_iter()\n+            .enumerate()\n+            .skip(start)\n+            .collect::<Vec<_>>();\n+        let coverage = TimelineCoverage {\n+            showing_turns: selected.len(),\n+            total_turns,\n+            has_more_before: start > 0,\n+            has_more_after: false,\n+        };\n+        let turns = timeline_turns(handle, &session_prefix, selected)?;\n+\n+        Ok(SessionTimeline {\n+            session_key: session_key.to_owned(),\n+            coverage,\n+            turns,\n+        })\n+    })\n+}\n+\n+fn timeline_turns(\n+    handle: &SessionTargetHandle<'_>,\n+    session_prefix: &str,\n+    summaries: Vec<(usize, StoredTurnSummary)>,\n+) -> Result<Vec<TimelineTurnOutline>> {\n+    if summaries.is_empty() {\n+        return Ok(Vec::new());\n+    }\n+\n+    let mut parts = Vec::with_capacity(summaries.len());\n+    let mut needed_hashes = HashSet::new();\n+    for (turn_index, summary) in summaries {\n+        let detail_key = format!(\"{session_prefix}:turn:{}\", summary.turn_key);\n+        let detail = read_turn_detail(handle, &detail_key)?;\n+        needed_hashes.extend(detail.records.iter().map(|record| record.record_hash.clone()));\n+        parts.push((turn_index, summary, detail.records, detail.observed_targets));\n+    }\n+\n+    let transcript_key = format!(\"{session_prefix}:transcript\");\n+    let records = compact_records_by_hash(handle, &transcript_key, &needed_hashes)?;\n+    parts\n+        .into_iter()\n+        .map(|(turn_index, summary, accepted_records, observed_targets)| {\n+            let turn_records = accepted_records\n+                .iter()\n+                .map(|record| {\n+                    records.get(&record.record_hash).with_context(|| {\n+                        format!(\n+                            \"turn detail references missing transcript record '{}'\",\n+                            record.record_hash\n+                        )\n+                    })\n+                })\n+                .collect::<Result<Vec<_>>>()?;\n+            Ok(turn_outline(\n+                turn_index,\n+                summary,\n+                &accepted_records,\n+                &turn_records,\n+                observed_targets,\n+            ))\n+        })\n+        .collect()\n+}\n+\n+fn turn_outline(\n+    turn_index: usize,\n+    summary: StoredTurnSummary,\n+    accepted_records: &[AcceptedRecord],\n+    records: &[&CompactRecord],\n+    observed_targets: StoredObservedTargets,\n+) -> TimelineTurnOutline {\n+    TimelineTurnOutline {\n+        turn_index,\n+        turn_key: summary.turn_key,\n+        source_key: summary.source_key,\n+        previous_turn_key: summary.previous_turn_key,\n+        capture_kind: summary.capture_kind,\n+        captured_at: summary.captured_at,\n+        record_count: accepted_records.len(),\n+        record_index_range: record_index_range(records),\n+        environment_snapshot_status: summary.environment_snapshot_status,\n+        observed_targets: observed_target_keys(observed_targets),\n+        first_record_timestamp: records.first().and_then(|record| record.timestamp.clone()),\n+        last_record_timestamp: records.last().and_then(|record| record.timestamp.clone()),\n+        first_user_preview: first_user_preview(records),\n+        latest_user_preview: latest_role_preview(records, \"user\"),\n+        latest_assistant_preview: latest_role_preview(records, \"assistant\"),\n+        tool_counts: tool_counts(records),\n+    }\n+}\n+\n+#[derive(Clone)]\n+struct CompactRecord {\n+    record_hash: String,\n+    record_index: Option<usize>,\n+    timestamp: Option<String>,\n+    kind: Option<String>,\n+    role: Option<String>,\n+    text: Option<String>,\n+    source_event_kind: Option<String>,\n+    tool_name: Option<String>,\n+    has_command: bool,\n+}\n+\n+fn compact_records_by_hash(\n+    handle: &SessionTargetHandle<'_>,\n+    transcript_key: &str,\n+    needed_hashes: &HashSet<String>,\n+) -> Result<HashMap<String, CompactRecord>> {\n+    let Some(transcript_value) = handle\n+        .get_value(transcript_key)\n+        .with_context(|| format!(\"failed to read GitMeta key '{transcript_key}'\"))?\n+    else {\n+        bail!(\"existing GitMeta key '{transcript_key}' is missing\");\n+    };\n+    let MetaValue::List(entries) = transcript_value else {\n+        bail!(\"existing GitMeta key '{transcript_key}' is not a list\");\n+    };\n+\n+    let mut records = HashMap::with_capacity(needed_hashes.len());\n+    for entry in entries {\n+        let Ok(record) = serde_json::from_str::<Value>(&entry.value) else {\n+            continue;\n+        };\n+        let Some(record_hash) = record[\"record_hash\"].as_str() else {\n+            continue;\n+        };\n+        if !needed_hashes.contains(record_hash) {\n+            continue;\n+        };\n+        records.insert(record_hash.to_owned(), compact_record(record));\n+        if records.len() == needed_hashes.len() {\n+            break;\n+        }\n+    }\n+    Ok(records)\n+}\n+\n+fn compact_record(record: Value) -> CompactRecord {\n+    let record_hash = record[\"record_hash\"]\n+        .as_str()\n+        .unwrap_or_default()\n+        .to_owned();\n+    CompactRecord {\n+        record_hash,\n+        record_index: record[\"record_index\"].as_u64().map(|index| index as usize),\n+        timestamp: record[\"timestamp\"].as_str().map(ToOwned::to_owned),\n+        kind: record[\"kind\"].as_str().map(ToOwned::to_owned),\n+        role: record[\"role\"].as_str().map(ToOwned::to_owned),\n+        text: record[\"text\"].as_str().map(ToOwned::to_owned),\n+        source_event_kind: record[\"source_event_kind\"].as_str().map(ToOwned::to_owned),\n+        tool_name: record[\"tool_name\"].as_str().map(ToOwned::to_owned),\n+        has_command: record[\"tool_input\"][\"cmd\"].is_string()\n+            || record[\"tool_input\"][\"command\"].is_string(),\n+    }\n+}\n+\n+fn record_index_range(records: &[&CompactRecord]) -> RecordIndexRange {\n+    let mut indexes = records.iter().filter_map(|record| record.record_index);\n+    let Some(first) = indexes.next() else {\n+        return RecordIndexRange {\n+            start: None,\n+            end: None,\n+        };\n+    };\n+    let (start, end) = indexes.fold((first, first), |(start, end), index| {\n+        (start.min(index), end.max(index))\n+    });\n+    RecordIndexRange {\n+        start: Some(start),\n+        end: Some(end),\n+    }\n+}\n+\n+fn observed_target_keys(targets: StoredObservedTargets) -> ObservedTargetKeys {\n+    ObservedTargetKeys {\n+        branches: targets\n+            .branches\n+            .into_iter()\n+            .map(|target| target.key)\n+            .collect(),\n+        reviews: targets\n+            .reviews\n+            .into_iter()\n+            .map(|target| target.key)\n+            .collect(),\n+        changes: targets\n+            .changes\n+            .into_iter()\n+            .map(|target| target.key)\n+            .collect(),\n+    }\n+}\n+\n+fn first_user_preview(records: &[&CompactRecord]) -> Option<RecordPreview> {\n+    records\n+        .iter()\n+        .find(|record| record.role.as_deref() == Some(\"user\") && record.text.is_some())\n+        .and_then(|record| record_preview(record))\n+}\n+\n+fn latest_role_preview(records: &[&CompactRecord], role: &str) -> Option<RecordPreview> {\n+    records\n+        .iter()\n+        .rev()\n+        .find(|record| record.role.as_deref() == Some(role) && record.text.is_some())\n+        .and_then(|record| record_preview(record))\n+}\n+\n+fn record_preview(record: &CompactRecord) -> Option<RecordPreview> {\n+    Some(RecordPreview {\n+        timestamp: record.timestamp.clone(),\n+        source_event_kind: record.source_event_kind.clone(),\n+        text: compact_preview(record.text.as_deref()?),\n+    })\n+}\n+\n+fn compact_preview(text: &str) -> String {\n+    const PREVIEW_TEXT_CHARS: usize = 240;\n+\n+    let trimmed = text.trim();\n+    let mut chars = trimmed.chars();\n+    let mut preview = chars.by_ref().take(PREVIEW_TEXT_CHARS).collect::<String>();\n+    if chars.next().is_some() {\n+        preview.push_str(\"...\");\n+    }\n+    preview\n+}\n+\n+fn tool_counts(records: &[&CompactRecord]) -> ToolCounts {\n+    let mut counts = ToolCounts::default();\n+    for record in records {\n+        match record.kind.as_deref() {\n+            Some(\"tool_call\") => counts.tool_call_count += 1,\n+            Some(\"tool_result\") => counts.tool_result_count += 1,\n+            _ => {}\n+        }\n+        if record.has_command {\n+            counts.command_count += 1;\n+        }\n+        push_unique(&mut counts.tool_names, record.tool_name.as_deref());\n+    }\n+    counts\n+}\n+\n+fn push_unique(values: &mut Vec<String>, value: Option<&str>) {\n+    let Some(value) = value else {\n+        return;\n+    