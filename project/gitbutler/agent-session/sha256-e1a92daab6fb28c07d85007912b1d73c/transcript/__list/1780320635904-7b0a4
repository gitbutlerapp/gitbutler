    let gerrit_mode = if gerrit_mode_enabled {\n        but_workspace::ref_info::GerritMode::Enabled(db.gerrit_metadata())\n    } else {\n        but_workspace::ref_info::GerritMode::Disabled\n    };\n    let (head_info, ws) = but_workspace::head_info_and_workspace(\n        &repo,\n        &meta,\n        but_workspace::ref_info::Options {\n            traversal: but_graph::init::Options::limited(),\n            expensive_commit_info: true,\n            gerrit_mode,\n        },\n    )?;\n    let head_info = head_info.pruned_to_entrypoint();\n\n    but_workspace::legacy::push::workspace_branch_and_ancestors_push(\n        &repo,\n        &ws,\n        &head_info,\n        &mut db,\n        gerrit_mode_enabled,\n        with_force,\n        skip_force_push_protection,\n        ctx.legacy_project.force_push_protection,\n        branch,\n        run_hooks,\n        ctx.legacy_project.husky_hooks_enabled,\n        push_opts,\n    )?;\n\n    Ok(())\n}\n","tool_name":"exec_command","tool_kind":"exec","tool_input":null,"exit_code":0,"outcome":"succeeded","source_record":{"timestamp":"2026-06-01T13:25:24.612Z","type":"response_item","payload":{"type":"function_call_output","call_id":"[REDACTED:entropy]"}}}