{"source_key":"sha256-46306f7e5fd51cf460ea5434a8fefe6f","record_index":339,"record_hash":"sha256:f294fdf811c8ae0d60a9b306c99ee716dccbb997bf706d38323021fb141bce44","timestamp":"2026-06-09T08:25:57.236Z","kind":"tool_call","source_event_kind":"codex:response_item:function_call","role":null,"text":null,"tool_name":"exec","tool_kind":"other","tool_input":{"command":"call execute-sql {\"query\":\"WITH agent_cli AS (\\n  SELECT\\n    distinct_id,\\n    timestamp,\\n    toString(properties.agent) AS agent,\\n    toString(properties.command) AS command\\n  FROM events\\n  WHERE event = 'Cli'\\n    AND timestamp >= now() - INTERVAL 90 DAY\\n    AND properties.agent IS NOT NULL\\n    AND toString(properties.agent) != ''\\n)\\nSELECT\\n  uniqExact(distinct_id) AS agent_users_90d,\\n  uniqExactIf(distinct_id, timestamp >= now() - INTERVAL 30 DAY) AS agent_users_30d,\\n\\n  uniqExactIf(distinct_id, command = 'skillCheck') AS skill_check_users_90d,\\n  round(100 * skill_check_users_90d / agent_users_90d, 1) AS skill_check_pct_90d,\\n  uniqExactIf(distinct_id, command = 'skillCheck' AND timestamp >= now() - INTERVAL 30 DAY) AS skill_check_users_30d,\\n  round(100 * skill_check_users_30d / agent_users_30d, 1) AS skill_check_pct_30d,\\n\\n  uniqExactIf(distinct_id, command = 'skillInstall') AS skill_install_users_90d,\\n  round(100 * skill_install_users_90d / agent_users_90d, 1) AS skill_install_pct_90d,\\n  uniqExactIf(distinct_id, command = 'skillInstall' AND timestamp >= now() - INTERVAL 30 DAY) AS skill_install_users_30d,\\n  round(100 * skill_install_users_30d / agent_users_30d, 1) AS skill_install_pct_30d,\\n\\n  uniqExactIf(distinct_id, command IN ('skillCheck', 'skillInstall')) AS any_skill_maintenance_users_90d,\\n  round(100 * any_skill_maintenance_users_90d / agent_users_90d, 1) AS any_skill_maintenance_pct_90d,\\n  uniqExactIf(distinct_id, command IN ('skillCheck', 'skillInstall') AND timestamp >= now() - INTERVAL 30 DAY) AS any_skill_maintenance_users_30d,\\n  round(100 * any_skill_maintenance_users_30d / agent_users_30d, 1) AS any_skill_maintenance_pct_30d,\\n\\n  count() AS agent_cli_events_90d,\\n  countIf(timestamp >= now() - INTERVAL 30 DAY) AS agent_cli_events_30d,\\n  countIf(command = 'skillCheck') AS skill_check_events_90d,\\n  countIf(command = 'skillInstall') AS skill_install_events_90d\\nFROM agent_cli\\nLIMIT 100\",\"truncate\":true}"},"source_record":{"timestamp":"2026-06-09T08:25:57.236Z","type":"response_item","payload":{"type":"function_call","name":"exec","namespace":"mcp__posthog","call_id":"[REDACTED:entropy]"}}}