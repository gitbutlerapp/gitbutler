{"source_key":"sha256-46306f7e5fd51cf460ea5434a8fefe6f","record_index":350,"record_hash":"sha256:001343d41fae26d26c610b7b61ebaa167d8818fe797a871d6497bebda6ca5141","timestamp":"2026-06-09T08:26:16.818Z","kind":"tool_call","source_event_kind":"codex:response_item:function_call","role":null,"text":null,"tool_name":"exec","tool_kind":"other","tool_input":{"command":"call execute-sql {\"query\":\"WITH agent_cli AS (\\n  SELECT\\n    distinct_id,\\n    timestamp,\\n    toString(properties.agent) AS agent,\\n    toString(properties.command) AS command\\n  FROM events\\n  WHERE event = 'Cli'\\n    AND timestamp >= now() - INTERVAL 90 DAY\\n    AND properties.agent IS NOT NULL\\n    AND toString(properties.agent) != ''\\n)\\nSELECT\\n  agent,\\n  uniqExact(distinct_id) AS agent_users_90d,\\n  uniqExactIf(distinct_id, command = 'skillCheck') AS skill_check_users_90d,\\n  round(100 * skill_check_users_90d / agent_users_90d, 1) AS skill_check_pct_90d,\\n  uniqExactIf(distinct_id, command = 'skillInstall') AS skill_install_users_90d,\\n  round(100 * skill_install_users_90d / agent_users_90d, 1) AS skill_install_pct_90d,\\n  uniqExactIf(distinct_id, command IN ('skillCheck', 'skillInstall')) AS any_skill_maintenance_users_90d,\\n  round(100 * any_skill_maintenance_users_90d / agent_users_90d, 1) AS any_skill_maintenance_pct_90d,\\n  count() AS cli_events_90d,\\n  countIf(command IN ('skillCheck', 'skillInstall')) AS skill_maintenance_events_90d\\nFROM agent_cli\\nGROUP BY agent\\nHAVING agent_users_90d >= 2\\nORDER BY agent_users_90d DESC\\nLIMIT 100\",\"truncate\":true}"},"source_record":{"timestamp":"2026-06-09T08:26:16.818Z","type":"response_item","payload":{"type":"function_call","name":"exec","namespace":"mcp__posthog","call_id":"[REDACTED:entropy]"}}}