::refs::FullName> {\n+    let ref_name = segment\n+        .ref_name\n+        .as_ref()\n+        .context(\"Stack segment has no branch reference\")?;\n+    gix::refs::FullName::try_from(ref_name.full_name_bytes.clone()).map_err(|err| {\n+        anyhow::anyhow!(\n+            \"Invalid branch reference '{}': {err}\",\n+            ref_name.display_name\n+        )\n+    })\n+}\n+\n+fn segment_display_name(segment: &HeadInfoSegment) -> anyhow::Result<&str> {\n+    segment\n+        .ref_name\n+        .as_ref()\n+        .map(|ref_name| ref_name.display_name.as_str())\n+        .context(\"Stack segment has no branch reference\")\n+}\n+\n+fn stack_display_name(stack: &HeadInfoStack) -> Option<&str> {\n+    stack\n+        .segments\n+        .first()\n+        .and_then(|segment| segment.ref_name.as_ref())\n+        .map(|ref_name| ref_name.display_name.as_str())\n+}\n+\n+fn segment_tip(\n+    repo: &gix::Repository,\n+    segment: &HeadInfoSegment,\n+) -> anyhow::Result<gix::ObjectId> {\n+    if let Ok(ref_name) = segment_ref(segment)\n+        && let Some(reference) = repo.try_find_reference(ref_name.as_ref())?\n+        && let Some(id) = reference.try_id()\n+    {\n+        return Ok(id.detach());\n+    }\n+    segment\n+        .commits\n+        .first()\n+        .map(|commit| commit.id)\n+        .or(segment.base)\n+        .context(\"Stack segment has no tip\")\n+}\n+\n+fn stack_tip(repo: &gix::Repository, stack: &HeadInfoStack) -> anyhow::Result<gix::ObjectId> {\n+    let segment = stack.segments.first().context(\"Stack has no segments\")?;\n+    segment_tip(repo, segment)\n+}\n+\n+fn delete_segment_reference(\n+    repo: &gix::Repository,\n+    segment: &HeadInfoSegment,\n+) -> anyhow::Result<()> {\n+    let ref_name = segment_ref(segment)?;\n+    if let Some(reference) = repo.try_find_reference(ref_name.as_ref())? {\n+        but_core::branch::SafeDelete::new(repo)?.delete_reference(&reference)?;\n+    }\n+    Ok(())\n+}\n+\n+fn stack_as_rebase_steps(\n+    repo: &gix::Repository,\n+    stack: &HeadInfoStack,\n+) -> anyhow::Result<Vec<RebaseStep>> {\n+    let mut steps = Vec::new();\n+    for segment in &stack.segments {\n+        let ref_name = segment\n+            .ref_name\n+            .as_ref()\n+            .context(\"Stack segment has no branch reference\")?;\n+        let full_name = segment_ref(segment)?;\n+        let reference_step = if repo.try_find_reference(full_name.as_ref())?.is_some() {\n+            RebaseStep::Reference(Reference::Git(full_name))\n+        } else {\n+            RebaseStep::Reference(Reference::Virtual(ref_name.display_name.clone()))\n+        };\n+        steps.push(reference_step);\n+        for commit in &segment.commits {\n+            steps.push(RebaseStep::Pick {\n+                commit_id: commit.id,\n+                new_message: None,\n+            });\n+        }\n+    }\n+    steps.reverse();\n+    Ok(steps)\n+}\n@@\n-#[expect(deprecated, reason = \"calls but_workspace::legacy::stack_details_v3\")]\n-fn stack_details(\n-    ctx: &Context,\n-    stack_id: Option<StackId>,\n-) -> anyhow::Result<but_workspace::ui::StackDetails> {\n-    let repo = ctx.clone_repo_for_merging_non_persisting()?;\n-    let meta = ctx.legacy_meta()?;\n-    but_workspace::legacy::stack_details_v3(stack_id, &repo, &meta)\n-}\n-\n /// Returns the status of a stack.\n fn get_stack_status(\n*** End Patch\n","source_record":{"timestamp":"2026-06-03T16:45:15.181Z","type":"response_item","payload":{"type":"custom_tool_call","status":"completed","call_id":"[REDACTED:entropy]","name":"apply_patch"}}}