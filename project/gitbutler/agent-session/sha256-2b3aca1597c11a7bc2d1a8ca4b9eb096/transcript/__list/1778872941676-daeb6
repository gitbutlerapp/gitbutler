ith a resolved projected target_commit\"\n+        );\n+\n+        ws.target_ref = None;\n+        ws.target_commit = None;\n+\n+        assert!(\n+            ws.target_ref.is_none(),\n+            \"direct projected target_ref access should reproduce the old failure\"\n+        );\n+        assert!(\n+            ws.target_commit_id().is_none(),\n+            \"direct projected target_commit access should reproduce the old failure\"\n+        );\n+        assert_eq!(\n+            ws.target_ref_name()\n+                .map(|target_ref| target_ref.as_bstr().to_string()),\n+            Some(metadata_target_ref),\n+            \"persisted metadata should still know the target_ref\"\n+        );\n+        assert_eq!(\n+            ws.target_base_commit_id(),\n+            Some(metadata_target_commit_id),\n+            \"persisted metadata should still know the target_commit_id\"\n+        );\n+    }\n+\n+    let actual =\n+        gitbutler_branch_actions::base::get_base_branch_data(ctx, guard.read_permission()).unwrap();\n+    assert_eq!(actual.branch_name, expected.branch_name);\n+    assert_eq!(actual.base_sha, expected.base_sha);\n+    assert_eq!(actual.current_sha, expected.current_sha);\n+}\n+\n mod error {\n     use gitbutler_reference::RemoteRefname;\n \n     use super::*;\n*** End Patch\n","source_record":{"timestamp":"2026-05-15T19:21:41.898Z","type":"response_item","payload":{"type":"custom_tool_call","status":"completed","call_id":"[REDACTED:entropy]","name":"apply_patch"}}}