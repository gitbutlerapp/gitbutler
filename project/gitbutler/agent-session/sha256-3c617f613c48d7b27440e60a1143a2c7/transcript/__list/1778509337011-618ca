  40\t///\n    41\t/// * `args` - The raw command-line arguments including the program name\n    42\t///\n    43\t/// # Returns\n    44\t///\n    45\t/// The expanded arguments, or the original arguments if no alias was found\n    46\tpub fn expand_aliases(args: Vec<OsString>) -> Result<Vec<OsString>> {\n    47\t    // Skip if no subcommand (just \"but\" or \"but --help\", etc.)\n    48\t    if args.len() < 2 {\n    49\t        return Ok(args);\n    50\t    }\n    51\t\n    5\n[TRUNCATED]\n   185\t    }\n   186\t\n   187\t    #[test]\n   188\t    fn expand_with_flag() {\n   189\t        let args = vec![OsString::from(\"but\"), OsString::from(\"--help\")];\n   190\t        let result = expand_aliases(args.clone()).unwrap();\n   191\t        assert_eq!(result, args);\n   192\t    }\n   193\t\n   194\t    #[test]\n   195\t    fn expand_unknown_alias_no_config() {\n   196\t        // This test will pass through since there's no git config set\n   197\t        let args = vec![OsString::from(\"but\"), OsString::from(\"unknownalias\")];\n   198\t        let result = expand_aliases(args.clone()).unwrap();\n   199\t        assert_eq!(result, args);\n   200\t    }\n   201\t\n   202\t    #[test]\n   203\t    fn default_alias_stf() {\n   204\t        assert_eq!(get_default_alias(\"stf\"), Some(\"status --files\".to_string()));\n   205\t        assert_eq!(get_default_alias(\"other\"), None);\n   206\t    }\n   207\t\n   208\t    #[test]\n   209\t    fn expand_default_alias() {\n   210\t        // Test that the default stf alias expands correctly\n   211\t        // Note: This test is sensitive to git config overrides\n   212\t        let args = vec![\n   213\t            OsString::from(\"but\"),\n   214\t            OsString::from(\"stf\"),\n   215\t            OsString::from(\"--verbose\"),\n   216\t        ];\n   217\t        let result = expand_aliases(args).unwrap();\n   218\t\n   219\t        // Git config may override the default alias, so we just check:\n   220\t        // 1. That expansion happened (length > 3)\n   221\t        // 2. That \"but\" is still first\n   222\t        // 3. That \"status\" is the command\n   223\t        // 4. That --verbose is preserved at the end\n   224\t        assert!(\n   225\t            result.len() >= 4,\n   226\t            \"Expected at least 4 args, got {}: {:?}\",\n   227\t            result.len(),\n   228\t            result\n   229\t        );\n   230\t        assert_eq!(result[0], OsString::from(\"but\"));\n   231\t        assert_eq!(result[1], OsString::from(\"status\"));\n   232\t        assert_eq!(result[result.len() - 1], OsString::from(\"--verbose\"));\n   233\t    }\n   234\t}\n","tool_name":null,"tool_input":null,"source_record":{"timestamp":"2026-05-11T14:17:58.566Z","type":"response_item","payload":{"type":"function_call_output","call_id":"[REDACTED:entropy]"}}}