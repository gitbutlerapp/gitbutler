epo, &meta, options),\n+    }\n+}\n+\n+fn workspace_ref_for_edit_mode(repo: &gix::Repository) -> Option<&'static gix::refs::FullNameRef> {\n+    match repo.head() {\n+        Ok(head)\n+            if head.referent_name().is_some_and(|head_ref| {\n+                head_ref.as_bstr() == gitbutler_operating_modes::EDIT_BRANCH_REF\n+            }) =>\n+        {\n+            [\n+                gitbutler_operating_modes::WORKSPACE_BRANCH_REF,\n+                gitbutler_operating_modes::INTEGRATION_BRANCH_REF,\n+            ]\n+            .iter()\n+            .find_map(|&name| {\n+                let ref_name: &'static gix::refs::FullNameRef = name.try_into().ok()?;\n+                repo.try_find_reference(ref_name).ok().flatten()?;\n+                Some(ref_name)\n+            })\n+        }\n+        _ => None,\n+    }\n+}\n \n impl WorkspaceState {\n*** End Patch\n","source_record":{"timestamp":"2026-06-03T14:55:02.847Z","type":"response_item","payload":{"type":"custom_tool_call","status":"completed","call_id":"[REDACTED:entropy]","name":"apply_patch"}}}