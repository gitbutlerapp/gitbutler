{"source_key":"sha256-d1b343ed42a51085ffb3fbb074863c4f","record_index":3037,"record_hash":"sha256:e9691e093abd58f02873be8398342db4669800f0b29487a4bbcf9078bcd8d707","timestamp":"2026-06-04T22:28:11.913Z","kind":"tool_call","source_event_kind":"codex:response_item:function_call","role":null,"text":null,"tool_name":"exec","tool_kind":"other","tool_input":{"command":"call execute-sql {\"query\":\"WITH first_agent_commit AS (\\n  SELECT\\n    distinct_id,\\n    min(timestamp) AS first_at\\n  FROM events\\n  WHERE event = 'Cli'\\n    AND timestamp >= now() - INTERVAL 180 DAY\\n    AND timestamp < now() - INTERVAL 14 DAY\\n    AND properties.command = 'commit'\\n    AND isNotNull(properties.agent)\\n    AND properties.agent != ''\\n  GROUP BY distinct_id\\n), first_week_manual AS (\\n  SELECT\\n    e.distinct_id,\\n    count() AS manual_events,\\n    uniq(e.properties.actionName) AS manual_operation_count\\n  FROM events e\\n  INNER JOIN first_agent_commit f ON e.distinct_id = f.distinct_id\\n  WHERE e.event = 'tauri_command'\\n    AND e.timestamp >= f.first_at\\n    AND e.timestamp < f.first_at + INTERVAL 7 DAY\\n    AND isNotNull(e.properties.actionName)\\n    AND e.properties.actionName != ''\\n    AND ifNull(e.properties.failure, false) = false\\n  GROUP BY e.distinct_id\\n), retained AS (\\n  SELECT DISTINCT e.distinct_id\\n  FROM events e\\n  INNER JOIN first_agent_commit f ON e.distinct_id = f.distinct_id\\n  WHERE e.event = 'Cli'\\n    AND e.properties.command = 'commit'\\n    AND isNotNull(e.properties.agent)\\n    AND e.properties.agent != ''\\n    AND e.timestamp >= f.first_at + INTERVAL 7 DAY\\n    AND e.timestamp < f.first_at + INTERVAL 14 DAY\\n), user_flags AS (\\n  SELECT\\n    f.distinct_id,\\n    if(isNull(m.distinct_id), 0, 1) AS has_manual,\\n    if(isNull(r.distinct_id), 0, 1) AS retained,\\n    ifNull(m.manual_events, 0) AS manual_events,\\n    ifNull(m.manual_operation_count, 0) AS manual_operation_count\\n  FROM first_agent_commit f\\n  LEFT JOIN first_week_manual m ON f.distinct_id = m.distinct_id\\n  LEFT JOIN retained r ON f.distinct_id = r.distinct_id\\n)\\nSELECT\\n  if(has_manual = 1, 'agent + manual UI ops', 'agent-only CLI ops') AS cohort,\\n  count() AS users,\\n  round(count() / (SELECT count() FROM first_agent_commit) * 100, 1) AS pct_users,\\n  countIf(retained = 1) AS retained_users,\\n  round(countIf(retained = 1) / count() * 100, 1) AS retention_pct,\\n  round(avg(manual_events), 1) AS avg_manual_events,\\n  quantile(0.5)(manual_events) AS median_manual_events,\\n  round(avg(manual_operation_count), 1) AS avg_manual_operation_types\\nFROM user_flags\\nGROUP BY cohort\\nORDER BY users DESC\\nLIMIT 100\",\"truncate\":true}"},"source_record":{"timestamp":"2026-06-04T22:28:11.913Z","type":"response_item","payload":{"type":"function_call","name":"exec","namespace":"mcp__posthog","call_id":"[REDACTED:entropy]"}}}