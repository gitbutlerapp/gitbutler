{"source_key":"sha256-d1b343ed42a51085ffb3fbb074863c4f","record_index":3083,"record_hash":"sha256:41e555ddc6bc619e8aef34938feee87e95158d47d89884af696d0a3c8068c8a1","timestamp":"2026-06-04T22:29:54.948Z","kind":"tool_call","source_event_kind":"codex:response_item:function_call","role":null,"text":null,"tool_name":"exec","tool_kind":"other","tool_input":{"command":"call execute-sql {\"query\":\"WITH first_agent_commit AS (\\n  SELECT\\n    distinct_id,\\n    min(timestamp) AS first_at\\n  FROM events\\n  WHERE event = 'Cli'\\n    AND timestamp >= now() - INTERVAL 180 DAY\\n    AND timestamp < now() - INTERVAL 14 DAY\\n    AND properties.command = 'commit'\\n    AND isNotNull(properties.agent)\\n    AND properties.agent != ''\\n  GROUP BY distinct_id\\n), first_week_manual AS (\\n  SELECT DISTINCT e.distinct_id\\n  FROM events e\\n  INNER JOIN first_agent_commit f ON e.distinct_id = f.distinct_id\\n  WHERE e.event = 'tauri_command'\\n    AND e.timestamp >= f.first_at\\n    AND e.timestamp < f.first_at + INTERVAL 7 DAY\\n    AND isNotNull(e.properties.actionName)\\n    AND e.properties.actionName != ''\\n    AND ifNull(e.properties.failure, false) = false\\n), first_week_agent_cli AS (\\n  SELECT\\n    e.distinct_id,\\n    count() AS agent_cli_events,\\n    countIf(e.properties.command = 'commit') AS agent_commits,\\n    uniq(e.properties.command) AS command_breadth\\n  FROM events e\\n  INNER JOIN first_agent_commit f ON e.distinct_id = f.distinct_id\\n  WHERE e.event = 'Cli'\\n    AND e.timestamp >= f.first_at\\n    AND e.timestamp < f.first_at + INTERVAL 7 DAY\\n    AND isNotNull(e.properties.agent)\\n    AND e.properties.agent != ''\\n  GROUP BY e.distinct_id\\n), retained AS (\\n  SELECT DISTINCT e.distinct_id\\n  FROM events e\\n  INNER JOIN first_agent_commit f ON e.distinct_id = f.distinct_id\\n  WHERE e.event = 'Cli'\\n    AND e.properties.command = 'commit'\\n    AND isNotNull(e.properties.agent)\\n    AND e.properties.agent != ''\\n    AND e.timestamp >= f.first_at + INTERVAL 7 DAY\\n    AND e.timestamp < f.first_at + INTERVAL 14 DAY\\n), classified AS (\\n  SELECT\\n    a.distinct_id,\\n    if(a.distinct_id IN (SELECT distinct_id FROM first_week_manual), 'manual UI ops', 'agent-only CLI') AS manual_cohort,\\n    multiIf(a.agent_commits <= 2, '1-2 agent commits', a.agent_commits <= 10, '3-10 agent commits', a.agent_commits <= 30, '11-30 agent commits', '31+ agent commits') AS commit_band,\\n    a.agent_commits,\\n    a.command_breadth\\n  FROM first_week_agent_cli a\\n)\\nSELECT\\n  commit_band,\\n  manual_cohort,\\n  count() AS users,\\n  round(avg(agent_commits), 1) AS avg_agent_commits,\\n  round(avg(command_breadth), 1) AS avg_command_breadth,\\n  countIf(distinct_id IN (SELECT distinct_id FROM retained)) AS retained_users,\\n  round(countIf(distinct_id IN (SELECT distinct_id FROM retained)) / count() * 100, 1) AS retention_pct\\nFROM classified\\nGROUP BY commit_band, manual_cohort\\nHAVING users >= 20\\nORDER BY commit_band, manual_cohort\\nLIMIT 100\",\"truncate\":true}"},"source_record":{"timestamp":"2026-06-04T22:29:54.948Z","type":"response_item","payload":{"type":"function_call","name":"exec","namespace":"mcp__posthog","call_id":"[REDACTED:entropy]"}}}