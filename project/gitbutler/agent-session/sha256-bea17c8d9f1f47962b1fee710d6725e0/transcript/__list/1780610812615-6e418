{"source_key":"sha256-d1b343ed42a51085ffb3fbb074863c4f","record_index":2571,"record_hash":"sha256:977025b440dc8bbcfd6c3abd5147ae5067dbf0b95337b8cedf01edcda6c406e9","timestamp":"2026-06-04T22:02:31.369Z","kind":"tool_call","source_event_kind":"codex:response_item:function_call","role":null,"text":null,"tool_name":"exec","tool_kind":"other","tool_input":{"command":"call execute-sql {\"query\":\"WITH cli AS (SELECT distinct_id, timestamp, toString(properties.command) AS command, toString(properties.agent) AS agent, ifNull(toString(properties.error), '') AS error, toFloat(properties.durationMs) AS duration_ms FROM events WHERE event = 'Cli' AND timestamp >= now() - INTERVAL 180 DAY AND properties.agent IS NOT NULL AND toString(properties.agent) != ''), commits AS (SELECT * FROM cli WHERE command = 'commit'), firsts AS (SELECT distinct_id, min(timestamp) AS first_commit_ts, argMin(agent, timestamp) AS first_agent FROM commits GROUP BY distinct_id HAVING first_commit_ts >= now() - INTERVAL 166 DAY AND first_commit_ts < now() - INTERVAL 14 DAY), features AS (SELECT f.distinct_id AS distinct_id, f.first_agent AS first_agent, countIf(e.distinct_id != '') AS events_7d, uniqExactIf(e.command, e.distinct_id != '') AS commands_7d, countIf(e.command = 'commit') AS commits_7d, countIf(e.command = 'rub') AS rubs_7d, countIf(e.command = 'push') AS pushes_7d, countIf(e.command = 'branchNew') AS branch_new_7d, countIf(e.command = 'status') AS status_7d, countIf(e.command = 'diff') AS diff_7d, countIf(e.error != '' AND e.error != 'null') AS errors_7d, countIf(e.command = 'commit' AND e.error != '' AND e.error != 'null') AS commit_errors_7d, countIf(e.command = 'rub' AND e.error != '' AND e.error != 'null') AS rub_errors_7d, avgIf(e.duration_ms, e.duration_ms > 0) AS avg_duration_ms_7d FROM firsts f LEFT JOIN cli e ON e.distinct_id = f.distinct_id AND e.timestamp >= f.first_commit_ts AND e.timestamp < f.first_commit_ts + INTERVAL 7 DAY GROUP BY f.distinct_id, f.first_agent), retained AS (SELECT f.distinct_id AS distinct_id, max(r.distinct_id != '') AS retained FROM firsts f LEFT JOIN commits r ON r.distinct_id = f.distinct_id AND r.timestamp >= f.first_commit_ts + INTERVAL 7 DAY AND r.timestamp < f.first_commit_ts + INTERVAL 14 DAY GROUP BY f.distinct_id) SELECT if(r.retained, 'retained', 'churned') AS group_name, count() AS users, round(avg(events_7d), 1) AS avg_events_7d, round(quantile(0.5)(events_7d), 1) AS median_events_7d, round(avg(commands_7d), 1) AS avg_commands_7d, round(avg(commits_7d), 1) AS avg_commits_7d, round(avg(rubs_7d), 1) AS avg_rubs_7d, round(avg(pushes_7d), 1) AS avg_pushes_7d, round(100.0 * countIf(pushes_7d > 0) / users, 1) AS pct_pushed_7d, round(100.0 * countIf(rubs_7d > 0) / users, 1) AS pct_rub_7d, round(100.0 * countIf(errors_7d > 0) / users, 1) AS pct_any_error_7d, round(100.0 * countIf(commit_errors_7d > 0) / users, 1) AS pct_commit_error_7d, round(100.0 * countIf(rub_errors_7d > 0) / users, 1) AS pct_rub_error_7d, round(avg(avg_duration_ms_7d), 0) AS avg_duration_ms FROM features f INNER JOIN retained r ON r.distinct_id = f.distinct_id GROUP BY r.retained ORDER BY r.retained DESC LIMIT 100\",\"truncate\":true}"},"source_record":{"timestamp":"2026-06-04T22:02:31.369Z","type":"response_item","payload":{"type":"function_call","name":"exec","namespace":"mcp__posthog","call_id":"[REDACTED:entropy]"}}}