{"source_key":"sha256-d1b343ed42a51085ffb3fbb074863c4f","record_index":664,"record_hash":"sha256:fc2e8b7ec9b7474b2da0def423572abe9583bc5032d7bbb886a13662ade9508f","timestamp":"2026-06-03T21:31:11.427Z","kind":"tool_call","source_event_kind":"codex:response_item:function_call","role":null,"text":null,"tool_name":"exec","tool_kind":"other","tool_input":{"command":"call execute-sql {\"query\":\"SELECT agent, count() AS successful_update_runs, countIf(has_next) AS runs_with_later_cli_event, countIf(version_changed) AS runs_with_later_version_change, count(DISTINCT person_with_version_change) AS users_with_version_change, arraySlice(groupArrayIf(concat(before_version, ' -> ', next_version), version_changed), 1, 10) AS sample_version_changes FROM (SELECT u.agent AS agent, u.person_id AS person_id, u.before_version AS before_version, min(e.timestamp) IS NOT NULL AS has_next, argMinIf(JSONExtractString(e.properties, 'appVersion'), e.timestamp, e.timestamp IS NOT NULL) AS next_version, has_next AND next_version != '' AND next_version != before_version AS version_changed, if(version_changed, u.person_id, NULL) AS person_with_version_change FROM (SELECT distinct_id, person_id, timestamp AS update_ts, JSONExtractString(properties, 'agent') AS agent, JSONExtractString(properties, 'appVersion') AS before_version FROM events WHERE timestamp >= now() - INTERVAL 180 DAY AND event = 'Cli' AND JSONExtractString(properties, 'command') = 'update' AND notEmpty(JSONExtractString(properties, 'agent')) AND notEmpty(JSONExtractString(properties, 'appVersion')) AND empty(JSONExtractString(properties, 'error'))) AS u LEFT JOIN events AS e ON e.distinct_id = u.distinct_id AND e.event = 'Cli' AND e.timestamp > u.update_ts AND e.timestamp <= u.update_ts + INTERVAL 14 DAY AND notEmpty(JSONExtractString(e.properties, 'appVersion')) GROUP BY u.distinct_id, u.person_id, u.update_ts, u.agent, u.before_version) GROUP BY agent ORDER BY successful_update_runs DESC LIMIT 100\",\"truncate\":true}"},"source