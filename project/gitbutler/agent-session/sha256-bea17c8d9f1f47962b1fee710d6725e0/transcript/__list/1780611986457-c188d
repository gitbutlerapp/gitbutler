{"source_key":"sha256-d1b343ed42a51085ffb3fbb074863c4f","record_index":2931,"record_hash":"sha256:0117f5d4cd7df0ed6554e1f663164d4cff8fb4c24b8415f9027b3226c0a4e1e0","timestamp":"2026-06-04T22:25:01.052Z","kind":"tool_call","source_event_kind":"codex:response_item:function_call","role":null,"text":null,"tool_name":"exec","tool_kind":"other","tool_input":{"command":"call execute-sql {\"query\":\"WITH commit_users AS (\\n  SELECT\\n    distinct_id,\\n    max(if(isNotNull(properties.agent) AND properties.agent != '', 1, 0)) AS has_agent_commit\\n  FROM events\\n  WHERE event = 'Cli'\\n    AND timestamp >= now() - INTERVAL 90 DAY\\n    AND properties.command = 'commit'\\n  GROUP BY distinct_id\\n), agentic AS (\\n  SELECT distinct_id FROM commit_users WHERE has_agent_commit = 1\\n), non_agentic AS (\\n  SELECT distinct_id FROM commit_users WHERE has_agent_commit = 0\\n), desktop_shape AS (\\n  SELECT\\n    distinct_id,\\n    max(toFloatOrDefault(properties.branchCount, 0)) AS max_branch_count,\\n    max(toFloatOrDefault(properties.totalLanesInWorkspace, 0)) AS max_lanes,\\n    max(toFloatOrDefault(properties.lanesWithAssignments, 0)) AS max_lanes_with_assignments\\n  FROM events\\n  WHERE event = 'tauri_command'\\n    AND timestamp >= now() - INTERVAL 90 DAY\\n    AND (\\n      isNotNull(properties.branchCount)\\n      OR isNotNull(properties.totalLanesInWorkspace)\\n      OR isNotNull(properties.lanesWithAssignments)\\n    )\\n  GROUP BY distinct_id\\n)\\nSELECT\\n  'agentic_commit' AS cohort,\\n  (SELECT count() FROM agentic) AS users,\\n  count() AS users_with_shape,\\n  round(avg(max_branch_count), 2) AS avg_max_branch_count_shape_users,\\n  round(avg(max_lanes), 2) AS avg_max_lanes_shape_users,\\n  round(avg(max_lanes_with_assignments), 2) AS avg_max_assigned_lanes_shape_users,\\n  round(countIf(max_branch_count > 1) / (SELECT count() FROM agentic) * 100, 1) AS pct_all_branch_count_gt_1,\\n  round(countIf(max_lanes > 1) / (SELECT count() FROM agentic) * 100, 1) AS pct_all_lanes_gt_1,\\n  round(countIf(max_lanes_with_assignments > 1) / (SELECT count() FROM agentic) * 100, 1) AS pct_all_assigned_lanes_gt_1\\nFROM desktop_shape\\nWHERE distinct_id IN (SELECT distinct_id FROM agentic)\\nUNION ALL\\nSELECT\\n  'non_agentic_commit' AS cohort,\\n  (SELECT count() FROM non_agentic) AS users,\\n  count() AS users_with_shape,\\n  round(avg(max_branch_count), 2) AS avg_max_branch_count_shape_users,\\n  round(avg(max_lanes), 2) AS avg_max_lanes_shape_users,\\n  round(avg(max_lanes_with_assignments), 2) AS avg_max_assigned_lanes_shape_users,\\n  round(countIf(max_branch_count > 1) / (SELECT count() FROM non_agentic) * 100, 1) AS pct_all_branch_count_gt_1,\\n  round(countIf(max_lanes > 1) / (SELECT count() FROM non_agentic) * 100, 1) AS pct_all_lanes_gt_1,\\n  round(countIf(max_lanes_with_assignments > 1) / (SELECT count() FROM non_agentic) * 100, 1) AS pct_all_assigned_lanes_gt_1\\nFROM desktop_shape\\nWHERE distinct_id IN (SELECT distinct_id FROM non_agentic)\\nLIMIT 100\",\"truncate\":true}"},"source_record":{"timestamp":"2026-06-04T22:25:01.052Z","type":"response_item","payload":{"type":"function_call","name":"exec","namespace":"mcp__posthog","call_id":"[REDACTED:entropy]"}}}