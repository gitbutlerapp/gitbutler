{"source_key":"sha256-d1b343ed42a51085ffb3fbb074863c4f","record_index":2508,"record_hash":"sha256:c479b13aece0e8fe00934b7c040d2acc85d50d50497ee10232a08615d420a6b7","timestamp":"2026-06-04T22:00:28.304Z","kind":"tool_call","source_event_kind":"codex:response_item:function_call","role":null,"text":null,"tool_name":"exec","tool_kind":"other","tool_input":{"command":"call execute-sql {\"query\":\"WITH cli AS (SELECT distinct_id, timestamp, toString(properties.command) AS command, toString(properties.agent) AS agent, toString(properties.appVersion) AS app_version, toString(properties.releaseChannel) AS release_channel, toString(properties.error) AS error, toFloat(properties.durationMs) AS duration_ms FROM events WHERE event = 'Cli' AND timestamp >= now() - INTERVAL 180 DAY AND properties.agent IS NOT NULL AND toString(properties.agent) != ''), commits AS (SELECT * FROM cli WHERE command = 'commit'), firsts AS (SELECT distinct_id, min(timestamp) AS first_commit_ts, argMin(agent, timestamp) AS first_agent, argMin(app_version, timestamp) AS first_version, argMin(release_channel, timestamp) AS first_channel FROM commits GROUP BY distinct_id HAVING first_commit_ts >= now() - INTERVAL 166 DAY AND first_commit_ts < now() - INTERVAL 14 DAY), retained AS (SELECT f.distinct_id AS distinct_id, count(r.timestamp) > 0 AS retained_next_week FROM firsts f LEFT JOIN commits r ON r.distinct_id = f.distinct_id AND r.timestamp >= f.first_commit_ts + INTERVAL 7 DAY AND r.timestamp < f.first_commit_ts + INTERVAL 14 DAY GROUP BY f.distinct_id) SELECT first_agent, first_channel, count() AS starters, countIf(retained_next_week) AS retained, round(100.0 * retained / starters, 1) AS retention_pct FROM firsts f INNER JOIN retained r ON r.distinct_id = f.distinct_id GROUP BY first_agent, first_channel HAVING starters >= 20 ORDER BY starters DESC LIMIT 100\",\"truncate\":true}"},"source_record":{"timestamp":"2026-06-04T22:00:28.304Z","type":"response_item","payload":{"type":"function_call","name":"e