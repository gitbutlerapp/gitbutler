{"source_key":"sha256-d1b343ed42a51085ffb3fbb074863c4f","record_index":2673,"record_hash":"sha256:d4ff0d4a47b84e66dab7bd8d150ffecdcdfe00ab917fe68cfcb82ed08e318375","timestamp":"2026-06-04T22:05:21.975Z","kind":"tool_call","source_event_kind":"codex:response_item:function_call","role":null,"text":null,"tool_name":"exec","tool_kind":"other","tool_input":{"command":"call execute-sql {\"query\":\"WITH user_errors AS (SELECT distinct_id, toString(properties.agent) AS agent, count() AS commit_events, countIf(ifNull(toString(properties.error), '') != '' AND ifNull(toString(properties.error), '') != 'null') AS user_error_events FROM events WHERE event = 'Cli' AND timestamp >= now() - INTERVAL 30 DAY AND toString(properties.command) = 'commit' AND toString(properties.appVersion) = '0.20.0' AND properties.agent IS NOT NULL AND toString(properties.agent) != '' GROUP BY distinct_id, agent), by_agent AS (SELECT agent, count() AS users, countIf(user_error_events > 0) AS users_with_errors, sum(commit_events) AS events, sum(user_error_events) AS total_error_events, max(user_error_events) AS max_errors_one_user FROM user_errors GROUP BY agent) SELECT agent, users, users_with_errors, round(100.0 * users_with_errors / users, 1) AS user_error_rate, events, total_error_events AS error_events, round(100.0 * total_error_events / events, 1) AS event_error_rate, max_errors_one_user, round(100.0 * max_errors_one_user / total_error_events, 1) AS max_user_share_of_errors FROM by_agent ORDER BY users DESC LIMIT 100\",\"truncate\":true}"},"source_record":{"timestamp":"2026-06-04T22:05:21.975Z","type":"response_item","payload":{"type":"function_call","name":"exec","namespace":"mcp__posthog","call_id":"[REDACTED:entropy]"}}}