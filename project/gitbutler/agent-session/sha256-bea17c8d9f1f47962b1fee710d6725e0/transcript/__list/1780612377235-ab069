ount() FROM retained WHERE distinct_id IN (SELECT distinct_id FROM first_week_manual_cli)) AS manual_cli_retained,\\n  round((SELECT count() FROM retained WHERE distinct_id IN (SELECT distinct_id FROM first_week_manual_cli)) / (SELECT count() FROM first_week_manual_cli) * 100, 1) AS manual_cli_retention_pct,\\n  (SELECT count() FROM retained WHERE distinct_id NOT IN (SELECT distinct_id FROM first_week_manual_cli)) AS no_manual_cli_retained,\\n  round((SELECT count() FROM retained WHERE distinct_id NOT IN (SELECT distinct_id FROM first_week_manual_cli)) / ((SELECT count() FROM first_agent_commit) - (SELECT count() FROM first_week_manual_cli)) * 100, 1) AS no_manual_cli_retention_pct\\nLIMIT 100\",\"truncate\":true}"},"source_record":{"timestamp":"2026-06-04T22:30:29.612Z","type":"response_item","payload":{"type":"function_call","name":"exec","namespace":"mcp__posthog","call_id":"[REDACTED:entropy]"}}}