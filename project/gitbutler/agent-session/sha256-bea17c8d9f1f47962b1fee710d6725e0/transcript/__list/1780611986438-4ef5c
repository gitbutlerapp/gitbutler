{"source_key":"sha256-d1b343ed42a51085ffb3fbb074863c4f","record_index":2885,"record_hash":"sha256:54f8bb9c629a9edb85f33c4f7baf4371ccffd4839add83585d351d8b569aa2ec","timestamp":"2026-06-04T22:23:38.666Z","kind":"tool_call","source_event_kind":"codex:response_item:function_call","role":null,"text":null,"tool_name":"exec","tool_kind":"other","tool_input":{"command":"call execute-sql {\"query\":\"WITH agentic_commit_users AS (\\n  SELECT\\n    distinct_id,\\n    argMax(properties.agent, timestamp) AS primary_agent\\n  FROM events\\n  WHERE event = 'Cli'\\n    AND timestamp >= now() - INTERVAL 90 DAY\\n    AND properties.command = 'commit'\\n    AND isNotNull(properties.agent)\\n    AND properties.agent != ''\\n  GROUP BY distinct_id\\n), desktop_shape AS (\\n  SELECT\\n    distinct_id,\\n    max(toFloatOrDefault(properties.branchCount, 0)) AS max_branch_count,\\n    max(toFloatOrDefault(properties.totalLanesInWorkspace, 0)) AS max_lanes,\\n    max(toFloatOrDefault(properties.lanesWithAssignments, 0)) AS max_lanes_with_assignments\\n  FROM events\\n  WHERE event = 'tauri_command'\\n    AND timestamp >= now() - INTERVAL 90 DAY\\n    AND (\\n      isNotNull(properties.branchCount)\\n      OR isNotNull(properties.totalLanesInWorkspace)\\n      OR isNotNull(properties.lanesWithAssignments)\\n    )\\n  GROUP BY distinct_id\\n)\\nSELECT\\n  primary_agent AS agent,\\n  count() AS users,\\n  round(avg(d.max_lanes), 2) AS avg_max_lanes,\\n  round(avg(d.max_lanes_with_assignments), 2) AS avg_max_assigned_lanes,\\n  round(countIf(d.max_lanes > 1) / count() * 100, 1) AS pct_lanes_gt_1,\\n  round(countIf(d.max_lanes_with_assignments > 1) / count() * 100, 1) AS pct_assigned_lanes_gt_1\\nFROM agentic_commit_users a\\nLEFT JOIN desktop_shape d ON a.distinct_id = d.distinct_id\\nGROUP BY agent\\nHAVING users >= 10\\nORDER BY users DESC\\nLIMIT 100\",\"truncate\":true}"},"source_record":{"timestamp":"2026-06-04T22:23:38.666Z","type":"response_item","payload":{"type":"function_call","name":"exec","namespace":"mcp__posthog","call_id":"[REDACTED:entropy]"}}}