{"source_key":"sha256-d1b343ed42a51085ffb3fbb074863c4f","record_index":3072,"record_hash":"sha256:f61bab3db31b442bcd6b9bca72db9b34390c65b9d3d6991595335a3f113909d3","timestamp":"2026-06-04T22:29:23.380Z","kind":"tool_call","source_event_kind":"codex:response_item:function_call","role":null,"text":null,"tool_name":"exec","tool_kind":"other","tool_input":{"command":"call execute-sql {\"query\":\"WITH first_agent_commit AS (\\n  SELECT\\n    distinct_id,\\n    min(timestamp) AS first_at\\n  FROM events\\n  WHERE event = 'Cli'\\n    AND timestamp >= now() - INTERVAL 180 DAY\\n    AND timestamp < now() - INTERVAL 14 DAY\\n    AND properties.command = 'commit'\\n    AND isNotNull(properties.agent)\\n    AND properties.agent != ''\\n  GROUP BY distinct_id\\n), first_week_manual AS (\\n  SELECT\\n    e.distinct_id,\\n    max(if(e.properties.actionName = 'Commit', 1, 0)) AS has_manual_commit,\\n    max(if(e.properties.actionName != 'Commit', 1, 0)) AS has_other_manual_op,\\n    count() AS manual_events,\\n    uniq(e.properties.actionName) AS manual_operation_count\\n  FROM events e\\n  INNER JOIN first_agent_commit f ON e.distinct_id = f.distinct_id\\n  WHERE e.event = 'tauri_command'\\n    AND e.timestamp >= f.first_at\\n    AND e.timestamp < f.first_at + INTERVAL 7 DAY\\n    AND isNotNull(e.properties.actionName)\\n    AND e.properties.actionName != ''\\n    AND ifNull(e.properties.failure, false) = false\\n  GROUP BY e.distinct_id\\n), retained AS (\\n  SELECT DISTINCT e.distinct_id\\n  FROM events e\\n  INNER JOIN first_agent_commit f ON e.distinct_id = f.distinct_id\\n  WHERE e.event = 'Cli'\\n    AND e.properties.command = 'commit'\\n    AND isNotNull(e.properties.agent)\\n    AND e.properties.agent != ''\\n    AND e.timestamp >= f.first_at + INTERVAL 7 DAY\\n    AND e.timestamp < f.first_at + INTERVAL 14 DAY\\n), classified AS (\\n  SELECT\\n    f.distinct_id,\\n    multiIf(\\n      f.distinct_id IN (SELECT distinct_id FROM first_week_manual WHERE has_manual_commit = 1), 'agent + desktop commit',\\n      f.distinct_id IN (SELECT distinct_id FROM first_week_manual), 'agent + other desktop ops',\\n      'agent-only CLI'\\n    ) AS cohort\\n  FROM first_agent_commit f\\n)\\nSELECT\\n  cohort,\\n  count() AS users,\\n  round(count() / (SELECT count() FROM first_agent_commit) * 100, 1) AS pct_users,\\n  countIf(distinct_id IN (SELECT distinct_id FROM retained)) AS retained_users,\\n  round(countIf(distinct_id IN (SELECT distinct_id FROM retained)) / count() * 100, 1) AS retention_pct\\nFROM classified\\nGROUP BY cohort\\nORDER BY users DESC\\nLIMIT 100\",\"truncate\":true}"},"source_record":{"timestamp":"2026-06-04T22:29:23.380Z","type":"response_item","payload":{"type":"function_call","name":"exec","namespace":"mcp__posthog","call_id":"[REDACTED:entropy]"}}}