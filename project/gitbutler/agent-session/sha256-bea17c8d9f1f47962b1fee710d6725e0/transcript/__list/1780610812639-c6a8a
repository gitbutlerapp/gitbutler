{"source_key":"sha256-d1b343ed42a51085ffb3fbb074863c4f","record_index":2623,"record_hash":"sha256:5bfad1f7b7d5b4f0b23707ab87216598b926dfa9275ad9acb2d546bc15113376","timestamp":"2026-06-04T22:04:18.960Z","kind":"tool_call","source_event_kind":"codex:response_item:function_call","role":null,"text":null,"tool_name":"exec","tool_kind":"other","tool_input":{"command":"call execute-sql {\"query\":\"WITH cli AS (SELECT distinct_id, timestamp, toString(properties.command) AS command, toString(properties.agent) AS agent, toString(properties.appVersion) AS app_version FROM events WHERE event = 'Cli' AND timestamp >= now() - INTERVAL 180 DAY AND properties.agent IS NOT NULL AND toString(properties.agent) != ''), commits AS (SELECT * FROM cli WHERE command = 'commit'), firsts AS (SELECT distinct_id, min(timestamp) AS first_commit_ts, argMin(agent, timestamp) AS first_agent, argMin(app_version, timestamp) AS first_version FROM commits GROUP BY distinct_id HAVING first_commit_ts >= now() - INTERVAL 166 DAY AND first_commit_ts < now() - INTERVAL 14 DAY), retained AS (SELECT f.distinct_id AS distinct_id, max(r.distinct_id != '') AS retained FROM firsts f LEFT JOIN commits r ON r.distinct_id = f.distinct_id AND r.timestamp >= f.first_commit_ts + INTERVAL 7 DAY AND r.timestamp < f.first_commit_ts + INTERVAL 14 DAY GROUP BY f.distinct_id) SELECT first_version, count() AS users, countIf(retained) AS retained_users, round(100.0 * retained_users / users, 1) AS retention_pct, uniqExact(first_agent) AS agent_count FROM firsts f INNER JOIN retained r ON r.distinct_id = f.distinct_id GROUP BY first_version HAVING users >= 10 ORDER BY users DESC LIMIT 100\",\"truncate\":true}"},"source_record":{"timestamp":"2026-06-04T22:04:18.960Z","type":"response_item","payload":{"type":"function_call","name":"exec","namespace":"mcp__posthog","call_id":"[REDACTED:entropy]"}}}