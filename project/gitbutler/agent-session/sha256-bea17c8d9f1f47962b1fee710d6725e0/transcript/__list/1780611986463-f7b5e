{"source_key":"sha256-d1b343ed42a51085ffb3fbb074863c4f","record_index":2945,"record_hash":"sha256:d5980cc6cb6c3350047786fb1ce5c1fb9486bbdf4c18b3f5307f4a182ac35781","timestamp":"2026-06-04T22:25:35.733Z","kind":"tool_call","source_event_kind":"codex:response_item:function_call","role":null,"text":null,"tool_name":"exec","tool_kind":"other","tool_input":{"command":"call execute-sql {\"query\":\"WITH first_agent_commit AS (\\n  SELECT\\n    distinct_id,\\n    min(timestamp) AS first_at\\n  FROM events\\n  WHERE event = 'Cli'\\n    AND timestamp >= now() - INTERVAL 90 DAY\\n    AND properties.command = 'commit'\\n    AND isNotNull(properties.agent)\\n    AND properties.agent != ''\\n  GROUP BY distinct_id\\n), first_week_agent_cli AS (\\n  SELECT\\n    e.distinct_id,\\n    count() AS agent_cli_events,\\n    countIf(e.properties.command = 'commit') AS commits,\\n    countIf(e.properties.command = 'branchNew') AS branch_new,\\n    countIf(e.properties.command IN ('branchMove', 'move')) AS branch_or_commit_move,\\n    countIf(e.properties.command IN ('rub', 'stage', 'unstage', 'amend', 'squash')) AS change_routing_commands,\\n    countIf(e.properties.command = 'push') AS push,\\n    uniq(e.properties.command) AS command_breadth\\n  FROM events e\\n  INNER JOIN first_agent_commit f ON e.distinct_id = f.distinct_id\\n  WHERE e.event = 'Cli'\\n    AND e.timestamp >= f.first_at\\n    AND e.timestamp < f.first_at + INTERVAL 7 DAY\\n    AND isNotNull(e.properties.agent)\\n    AND e.properties.agent != ''\\n  GROUP BY e.distinct_id\\n)\\nSELECT\\n  (SELECT count() FROM first_agent_commit) AS agentic_commit_users,\\n  count() AS users_with_first_week_agent_cli,\\n  round(avg(commits), 1) AS avg_agent_commits,\\n  round(avg(command_breadth), 1) AS avg_agent_command_breadth,\\n  round(countIf(commits >= 2) / (SELECT count() FROM first_agent_commit) * 100, 1) AS pct_two_plus_agent_commits,\\n  round(countIf(branch_new > 0) / (SELECT count() FROM first_agent_commit) * 100, 1) AS pct_agent_branch_new,\\n  round(countIf(branch_or_commit_move > 0) / (SELECT count() FROM first_agent_commit) * 100, 1) AS pct_agent_move,\\n  round(countIf(change_routing_commands > 0) / (SELECT count() FROM first_agent_commit) * 100, 1) AS pct_agent_change_routing,\\n  round(countIf(push > 0) / (SELECT count() FROM first_agent_commit) * 100, 1) AS pct_agent_push\\nFROM first_week_agent_cli\\nLIMIT 100\",\"truncate\":true}"},"source_record":{"timestamp":"2026-06-04T22:25:35.733Z","type":"response_item","payload":{"type":"function_call","name":"exec","namespace":"mcp__posthog","call_id":"[REDACTED:entropy]"}}}