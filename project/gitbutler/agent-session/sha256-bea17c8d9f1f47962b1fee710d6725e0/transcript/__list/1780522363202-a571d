{"source_key":"sha256-d1b343ed42a51085ffb3fbb074863c4f","record_index":675,"record_hash":"sha256:de0a22afa06087ea48d8041f5362df93984f63ca294f009d8b370a91eb456193","timestamp":"2026-06-03T21:31:31.855Z","kind":"tool_call","source_event_kind":"codex:response_item:function_call","role":null,"text":null,"tool_name":"exec","tool_kind":"other","tool_input":{"command":"call execute-sql {\"query\":\"SELECT agent, count() AS successful_update_runs_with_next_event, countIf(next_version != before_version) AS runs_with_next_version_change, count(DISTINCT if(next_version != before_version, person_id, NULL)) AS users_with_next_version_change, arraySlice(groupArrayIf(concat(before_version, ' -> ', next_version), next_version != before_version), 1, 10) AS sample_changes FROM (SELECT u.distinct_id AS distinct_id, u.person_id AS person_id, u.update_ts AS update_ts, u.agent AS agent, u.before_version AS before_version, argMin(JSONExtractString(e.properties, 'appVersion'), e.timestamp) AS next_version FROM (SELECT distinct_id, person_id, timestamp AS update_ts, JSONExtractString(properties, 'agent') AS agent, JSONExtractString(properties, 'appVersion') AS before_version FROM events WHERE timestamp >= now() - INTERVAL 180 DAY AND event = 'Cli' AND JSONExtractString(properties, 'command') = 'update' AND notEmpty(JSONExtractString(properties, 'agent')) AND notEmpty(JSONExtractString(properties, 'appVersion')) AND empty(JSONExtractString(properties, 'error'))) AS u INNER JOIN events AS e ON e.distinct_id = u.distinct_id AND e.event = 'Cli' AND e.timestamp > u.update_ts AND e.timestamp <= plus(u.update_ts, toIntervalDay(14)) AND notEmpty(JSONExtractString(e.properties, 'appVersion')) GROUP BY u.distinct_id, u.person_id, u.update_ts, u.agent, u.before_version) GROUP BY agent ORDER BY successful_update_runs_with_next_event DESC LIMIT 100\",\"truncate\":true}"},"source_record":{"timestamp":"2026-06-03T21:31:31.855Z","type":"response_item","payload":{"type":"function_call","name":"exec","namespace":"mcp__posthog","call_id":"[REDACTED:entropy]"}}}