{"source_key":"sha256-d1b343ed42a51085ffb3fbb074863c4f","record_index":2924,"record_hash":"sha256:716333286a28074658a7e17ceccc6675e57bb7d185922395a0e4f4f7863ff827","timestamp":"2026-06-04T22:24:42.959Z","kind":"tool_call","source_event_kind":"codex:response_item:function_call","role":null,"text":null,"tool_name":"exec","tool_kind":"other","tool_input":{"command":"call execute-sql {\"query\":\"WITH commit_users AS (\\n  SELECT\\n    distinct_id,\\n    max(if(isNotNull(properties.agent) AND properties.agent != '', 1, 0)) AS has_agent_commit\\n  FROM events\\n  WHERE event = 'Cli'\\n    AND timestamp >= now() - INTERVAL 90 DAY\\n    AND properties.command = 'commit'\\n  GROUP BY distinct_id\\n), desktop_shape AS (\\n  SELECT\\n    distinct_id,\\n    max(toFloatOrDefault(properties.branchCount, 0)) AS max_branch_count,\\n    max(toFloatOrDefault(properties.totalLanesInWorkspace, 0)) AS max_lanes,\\n    max(toFloatOrDefault(properties.lanesWithAssignments, 0)) AS max_lanes_with_assignments\\n  FROM events\\n  WHERE event = 'tauri_command'\\n    AND timestamp >= now() - INTERVAL 90 DAY\\n    AND distinct_id IN (SELECT distinct_id FROM commit_users)\\n    AND (\\n      isNotNull(properties.branchCount)\\n      OR isNotNull(properties.totalLanesInWorkspace)\\n      OR isNotNull(properties.lanesWithAssignments)\\n    )\\n  GROUP BY distinct_id\\n), user_shape AS (\\n  SELECT\\n    c.distinct_id,\\n    c.has_agent_commit,\\n    if(isNull(d.distinct_id), 0, 1) AS has_shape,\\n    ifNull(d.max_branch_count, 0) AS max_branch_count,\\n    ifNull(d.max_lanes, 0) AS max_lanes,\\n    ifNull(d.max_lanes_with_assignments, 0) AS max_lanes_with_assignments\\n  FROM commit_users c\\n  LEFT JOIN desktop_shape d ON c.distinct_id = d.distinct_id\\n)\\nSELECT\\n  if(has_agent_commit = 1, 'agentic_commit', 'non_agentic_commit') AS cohort,\\n  count() AS users,\\n  countIf(has_shape = 1) AS users_with_shape,\\n  round(avg(max_branch_count), 2) AS avg_max_branch_count,\\n  round(avg(max_lanes), 2) AS avg_max_lanes,\\n  round(avg(max_lanes_with_assignments), 2) AS avg_max_assigned_lanes,\\n  round(countIf(max_branch_count > 1) / count() * 100, 1) AS pct_branch_count_gt_1,\\n  round(countIf(max_lanes > 1) / count() * 100, 1) AS pct_lanes_gt_1,\\n  round(countIf(max_lanes_with_assignments > 1) / count() * 100, 1) AS pct_assigned_lanes_gt_1\\nFROM user_shape\\nGROUP BY cohort\\nORDER BY cohort\\nLIMIT 100\",\"truncate\":true}"},"source_record":{"timestamp":"2026-06-04T22:24:42.959Z","type":"response_item","payload":{"type":"function_call","name":"exec","namespace":"mcp__posthog","call_id":"[REDACTED:entropy]"}}}