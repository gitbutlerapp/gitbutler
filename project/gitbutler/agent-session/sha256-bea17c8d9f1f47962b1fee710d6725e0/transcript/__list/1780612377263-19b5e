{"source_key":"sha256-d1b343ed42a51085ffb3fbb074863c4f","record_index":3155,"record_hash":"sha256:5d9c467f63fe9f63ad1203c3d46e1f5e4cae01e6911009fd98e106b1ef9bf589","timestamp":"2026-06-04T22:32:37.083Z","kind":"tool_call","source_event_kind":"codex:response_item:function_call","role":null,"text":null,"tool_name":"exec","tool_kind":"other","tool_input":{"command":"call execute-sql {\"query\":\"WITH first_agent_commit AS (\\n  SELECT\\n    distinct_id,\\n    min(timestamp) AS first_at\\n  FROM events\\n  WHERE event = 'Cli'\\n    AND timestamp >= now() - INTERVAL 180 DAY\\n    AND timestamp < now() - INTERVAL 14 DAY\\n    AND properties.command = 'commit'\\n    AND isNotNull(properties.agent)\\n    AND properties.agent != ''\\n  GROUP BY distinct_id\\n), desktop_manual AS (\\n  SELECT DISTINCT e.distinct_id\\n  FROM events e\\n  INNER JOIN first_agent_commit f ON e.distinct_id = f.distinct_id\\n  WHERE e.event = 'tauri_command'\\n    AND e.timestamp >= f.first_at\\n    AND e.timestamp < f.first_at + INTERVAL 7 DAY\\n    AND isNotNull(e.properties.actionName)\\n    AND e.properties.actionName != ''\\n    AND ifNull(e.properties.failure, false) = false\\n), manual_cli_write AS (\\n  SELECT DISTINCT e.distinct_id\\n  FROM events e\\n  INNER JOIN first_agent_commit f ON e.distinct_id = f.distinct_id\\n  WHERE e.event = 'Cli'\\n    AND e.timestamp >= f.first_at\\n    AND e.timestamp < f.first_at + INTERVAL 7 DAY\\n    AND (isNull(e.properties.agent) OR e.properties.agent = '')\\n    AND e.properties.command IN ('commit','commitEmpty','rub','push','branchNew','branchDelete','branchApply','branchUnapply','prNew','discard','absorb','reword','undo','redo','restore','amend','stage','unstage','uncommit','squash','move','branchMove','branchTearOff','merge','pick','clean')\\n), retained AS (\\n  SELECT DISTINCT e.distinct_id\\n  FROM events e\\n  INNER JOIN first_agent_commit f ON e.distinct_id = f.distinct_id\\n  WHERE e.event = 'Cli'\\n    AND e.properties.command = 'commit'\\n    AND isNotNull(e.properties.agent)\\n    AND e.properties.agent != ''\\n    AND e.timestamp >= f.first_at + INTERVAL 7 DAY\\n    AND e.timestamp < f.first_at + INTERVAL 14 DAY\\n), classified AS (\\n  SELECT\\n    distinct_id,\\n    multiIf(\\n      distinct_id IN (SELECT distinct_id FROM desktop_manual) AND distinct_id IN (SELECT distinct_id FROM manual_cli_write), 'desktop + manual CLI writes',\\n      distinct_id IN (SELECT distinct_id FROM desktop_manual), 'desktop manual only',\\n      distinct_id IN (SELECT distinct_id FROM manual_cli_write), 'manual CLI writes only',\\n      'agent-only'\\n    ) AS cohort\\n  FROM first_agent_commit\\n)\\nSELECT\\n  cohort,\\n  count() AS users,\\n  round(count() / (SELECT count() FROM first_agent_commit) * 100, 1) AS pct_users,\\n  countIf(distinct_id IN (SELECT distinct_id FROM retained)) AS retained_users,\\n  round(countIf(distinct_id IN (SELECT distinct_id FROM retained)) / count() * 100, 1) AS retention_pct\\nFROM classified\\nGROUP BY cohort\\nORDER BY users DESC\\nLIMIT 100\",\"truncate\":true}"},"source_record":{"timestamp":"2026-06-04T22:32:37.083Z","type":"response_item","payload":{"type":"function_call","name":"exec","namespace":"mcp__posthog","call_id":"[REDACTED:entropy]"}}}