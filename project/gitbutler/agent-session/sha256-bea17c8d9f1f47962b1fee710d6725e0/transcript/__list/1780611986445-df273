{"source_key":"sha256-d1b343ed42a51085ffb3fbb074863c4f","record_index":2902,"record_hash":"sha256:687731f962c2417000de1cf7b9e8b1cd7e4a5478cd0d69a0ba4e2d324df9844d","timestamp":"2026-06-04T22:24:04.442Z","kind":"tool_call","source_event_kind":"codex:response_item:function_call","role":null,"text":null,"tool_name":"exec","tool_kind":"other","tool_input":{"command":"call execute-sql {\"query\":\"WITH agentic_commit_users AS (\\n  SELECT DISTINCT distinct_id\\n  FROM events\\n  WHERE event = 'Cli'\\n    AND timestamp >= now() - INTERVAL 90 DAY\\n    AND properties.command = 'commit'\\n    AND isNotNull(properties.agent)\\n    AND properties.agent != ''\\n), stack_shape AS (\\n  SELECT\\n    distinct_id,\\n    max(toFloatOrDefault(properties.maxValue, 0)) AS max_stack_count\\n  FROM events\\n  WHERE event = 'metrics:max_stack_count'\\n    AND timestamp >= now() - INTERVAL 90 DAY\\n  GROUP BY distinct_id\\n), vb_shape AS (\\n  SELECT\\n    distinct_id,\\n    max(toFloatOrDefault(properties.maxValue, 0)) AS max_virtual_branch_count\\n  FROM events\\n  WHERE event = 'metrics:virtual_branch_count'\\n    AND timestamp >= now() - INTERVAL 90 DAY\\n  GROUP BY distinct_id\\n)\\nSELECT\\n  count() AS agentic_commit_users,\\n  countIf(isNotNull(s.distinct_id) OR isNotNull(v.distinct_id)) AS users_with_metric_shape,\\n  round(avg(s.max_stack_count), 2) AS avg_max_stack_count,\\n  round(avg(v.max_virtual_branch_count), 2) AS avg_max_virtual_branch_count,\\n  round(countIf(s.max_stack_count > 1) / count() * 100, 1) AS pct_max_stack_gt_1,\\n  round(countIf(v.max_virtual_branch_count > 1) / count() * 100, 1) AS pct_virtual_branch_gt_1\\nFROM agentic_commit_users a\\nLEFT JOIN stack_shape s ON a.distinct_id = s.distinct_id\\nLEFT JOIN vb_shape v ON a.distinct_id = v.distinct_id\\nLIMIT 100\",\"truncate\":true}"},"source_record":{"timestamp":"2026-06-04T22:24:04.442Z","type":"response_item","payload":{"type":"function_call","name":"exec","namespace":"mcp__posthog","call_id":"[REDACTED:en