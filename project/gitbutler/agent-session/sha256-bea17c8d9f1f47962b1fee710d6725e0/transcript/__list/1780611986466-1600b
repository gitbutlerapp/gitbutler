{"source_key":"sha256-d1b343ed42a51085ffb3fbb074863c4f","record_index":2952,"record_hash":"sha256:32ee6adaf2715c2b68fb80aaa788bb073f26e9c23450446e4594773a4c29f314","timestamp":"2026-06-04T22:25:47.209Z","kind":"tool_call","source_event_kind":"codex:response_item:function_call","role":null,"text":null,"tool_name":"exec","tool_kind":"other","tool_input":{"command":"call execute-sql {\"query\":\"WITH first_agent_commit AS (\\n  SELECT\\n    distinct_id,\\n    min(timestamp) AS first_at\\n  FROM events\\n  WHERE event = 'Cli'\\n    AND timestamp >= now() - INTERVAL 90 DAY\\n    AND properties.command = 'commit'\\n    AND isNotNull(properties.agent)\\n    AND properties.agent != ''\\n  GROUP BY distinct_id\\n), first_week_agent_cli AS (\\n  SELECT\\n    e.distinct_id,\\n    countIf(e.properties.command = 'commit') AS commits,\\n    uniq(e.properties.command) AS command_breadth\\n  FROM events e\\n  INNER JOIN first_agent_commit f ON e.distinct_id = f.distinct_id\\n  WHERE e.event = 'Cli'\\n    AND e.timestamp >= f.first_at\\n    AND e.timestamp < f.first_at + INTERVAL 7 DAY\\n    AND isNotNull(e.properties.agent)\\n    AND e.properties.agent != ''\\n  GROUP BY e.distinct_id\\n)\\nSELECT\\n  quantile(0.5)(commits) AS median_agent_commits,\\n  quantile(0.75)(commits) AS p75_agent_commits,\\n  quantile(0.9)(commits) AS p90_agent_commits,\\n  quantile(0.5)(command_breadth) AS median_command_breadth,\\n  quantile(0.75)(command_breadth) AS p75_command_breadth,\\n  quantile(0.9)(command_breadth) AS p90_command_breadth\\nFROM first_week_agent_cli\\nLIMIT 100\",\"truncate\":true}"},"source_record":{"timestamp":"2026-06-04T22:25:47.209Z","type":"response_item","payload":{"type":"function_call","name":"exec","namespace":"mcp__posthog","call_id":"[REDACTED:entropy]"}}}