{"source_key":"sha256-d1b343ed42a51085ffb3fbb074863c4f","record_index":2693,"record_hash":"sha256:66229dbcc80ab19850bcb87c0b471a244139d9cb3020aa187b4882a5c050c791","timestamp":"2026-06-04T22:06:24.239Z","kind":"tool_call","source_event_kind":"codex:response_item:function_call","role":null,"text":null,"tool_name":"render_table","tool_kind":"other","tool_input":{"title":"Agentic commit retention by first-week activation pattern","subtitle":"Users who reached a branch + rub + push flow were almost 4x as likely to commit again next week as users with neither rub nor push.","rows":[{"activation_pattern":"branch + rub + push","users":247,"retained_users":159,"retention_pct":64.4,"avg_events_7d":424.4,"avg_commands_7d":15.1,"pct_error_7d":97.6},{"activation_pattern":"rub + push","users":67,"retained_users":27,"retention_pct":40.3,"avg_events_7d":55.6,"avg_commands_7d":8.1,"pct_error_7d":83.6},{"activation_pattern":"rub, no push","users":170,"retained_users":61,"retention_pct":35.9,"avg_events_7d":110.8,"avg_commands_7d":8.6,"pct_error_7d":89.4},{"activation_pattern":"push, no rub","users":67,"retained_users":14,"retention_pct":20.9,"avg_events_7d":19.7,"avg_commands_7d":5.3,"pct_error_7d":52.2},{"activation_pattern":"no rub, no push","users":113,"retained_users":19,"retention_pct":16.8,"avg_events_7d":16.6,"avg_commands_7d":2.6,"pct_error_7d":41.6}],"columns":[{"key":"activation_pattern","label":"Activation pattern","type":"text"},{"key":"users","label":"Users","type":"number","format":"number"},{"key":"retained_users","label":"Retained users","type":"number","format":"number"},{"key":"retention_pct","label":"Retention","type":"percent"},{"key":"avg_events_7d","label":"Avg CLI events 7d","type":"number","format":"number"},{"key":"avg_commands_7d","label":"Avg command types 7d","type":"number","format":"number"},{"key":"pct_error_7d","label":"Had error","type":"percent"}],"source":{"label":"PostHog events","query":{"engine":"HogQL","language":"sql","description":"First observed agentic CLI committers in the last 180 days, excluding starters from the last 14 days; retained if they had another agentic `commit` event in days 7-13 after first commit. Activation pattern is based on agentic CLI commands during the first 7 days after the first commit.","tables_used":["events"],"metric_definitions":["Starter: distinct_id whose first observed `Cli` event with `command='commit'` and non-empty `agent` falls in the mature cohort window.","Retained: starter with another agentic `commit` event between 7 and 14 days after first observed agentic commit.","Activation pattern: first-week presence of `rub`, `push`, and `branchNew` commands."],"sql":"WITH cli AS (SELECT distinct_id, timestamp, toString(properties.command) AS command, toString(properties.agent) AS agent, ifNull(toString(properties.error), '') AS error FROM events WHERE event = 'Cli' AND timestamp >= now() - INTERVAL 180 DAY AND properties.agent IS NOT NULL AND toString(properties.agent) != ''), commits AS (SELECT * FROM cli WHERE command = 'commit'), firsts AS (SELECT distinct_id, min(timestamp) AS first_commit_ts, argMin(agent, timestamp) AS first_agent FROM commits GROUP BY distinct_id HAVING first_commit_ts >= now() - INTERVAL 166 DAY AND first_commit_ts < now() - INTERVAL 14 DAY), features AS (SELECT f.distinct_id AS distinct_id, f.first_agent AS first_agent, countIf(e.distinct_id != '') AS events_7d, uniqExactIf(e.command, e.distinct_id != '') AS commands_7d, countIf(e.command = 'commit') AS commits_7d, countIf(e.command = 'rub') AS rubs_7d, countIf(e.command = 'push') AS pushes_7d, countIf(e.command = 'branchNew') AS branch_new_7d, countIf(e.error != '' AND e.error != 'null') AS errors_7d FROM firsts f LEFT JOIN cli e ON e.distinct_id = f.distinct_id AND e.timestamp >= f.first_commit_ts AND e.timestamp < f.first_commit_ts + INTERVAL 7 DAY GROUP BY f.distinct_id, f.first_agent), retained AS (SELECT f.distinct_id AS distinct_id, max(r.distinct_id != '') AS retained FROM firsts f LEFT JOIN commits r ON r.distinct_id = f.distinct_id AND r.timestamp >= f.first_commit_ts + INTERVAL 7 DAY AND r.timestamp < f.first_commit_ts + INTERVAL 14 DAY GROUP BY f.distinct_id), labeled AS (SELECT f.*, r.retained AS retained FROM features f INNER JOIN retained r ON r.distinct_id = f.distinct_id) SELECT multiIf(rubs_7d = 0 AND pushes_7d = 0, 'no rub, no push', rubs_7d > 0 AND pushes_7d = 0, 'rub, no push', rubs_7d = 0 AND pushes_7d > 0, 'push, no rub', branch_new_7d > 0 AND rubs_7d > 0 AND pushes_7d > 0, 'branch + rub + push', rubs_7d > 0 AND pushes_7d > 0, 'rub + push', 'other') AS activation_pattern, count() AS users, countIf(retained) AS retained_users, round(100.0 * retained_users / users, 1) AS retention_pct, round(avg(events_7d), 1) AS avg_events_7d, round(avg(commands_7d), 1) AS avg_commands_7d, round(100.0 * countIf(errors_7d > 0) / users, 1) AS pct_error_7d FROM labeled GROUP BY activation_pattern HAVING users >= 10 ORDER BY retention_pct DESC LIMIT 100"}},"max_rows":10},"source_record":{"timestamp":"2026-06-04T22:06:24.239Z","type":"response_item","payload":{"type":"function_call","name":"render_table","namespace":"mcp__datascienceWidgets","call_id":"[REDACTED:entropy]"}}}