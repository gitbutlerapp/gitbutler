raft,\n    Completions,\n    AliasCheck,\n    AliasAdd,\n    AliasRemove,\n    RefreshRemoteData,\n    Resolve,\n    Update,\n    Merge,\n    SkillInstall,\n    SkillCheck,\n    Pick,\n    Clean,\n    #[default]\n    Unknown,\n}\n\nimpl CommandName {\n    /// Percentage sample rate, between 0 and 1.\n    ///\n    /// 1 indicates that the command should always be submitted to posthog, and\n    /// 0 should never be submitted to posthog.\n    pub fn sample_rate(&self) -> f32 {\n        match self {\n            Self::Unknown | Self::Completions | Self::Status => 0.05,\n            _ => 1.0,\n        }\n    }\n}\n","tool_name":"exec_command","tool_kind":"exec","tool_input":null,"exit_code":0,"outcome":"succeeded","source_record":{"timestamp":"2026-05-26T15:05:43.281Z","type":"response_item","payload":{"type":"function_call_output","call_id":"[REDACTED:entropy]"}}}