      }\n    }\n}\n\n#[derive(Clone, Default)]\npub struct SnapshotCache {\n    entries: Arc<Mutex<HashMap<SnapshotKey, Arc<ProjectionOutcome>>>>,\n}\n\nimpl SnapshotCache {\n    pub fn get(&self, key: &SnapshotKey) -> Option<Arc<ProjectionOutcome>> {\n        self.entries\n            .lock()\n            .expect(\"snapshot cache mutex poisoned\")\n            .get(key)\n            .cloned()\n    }\n\n    pub\n[TRUNCATED]\nget(&self, key: &SnapshotKey) -> Option<Option<AiSummary>> {\n        self.entries\n            .lock()\n            .expect(\"summary cache mutex poisoned\")\n            .get(key)\n            .cloned()\n    }\n\n    pub fn insert(&self, key: SnapshotKey, summary: Option<AiSummary>) {\n        let mut entries = self.entries.lock().expect(\"summary cache mutex poisoned\");\n        if entries.len() >= MAX_ENTRIES && !entries.contains_key(&key) {\n            entries.clear();\n        }\n        entries.insert(key, summary);\n    }\n}\n\n#[cfg(test)]\nmod tests {\n    use super::*;\n\n    fn pr_facts(number: u64, head_sha: &str) -> PrFacts {\n        PrFacts {\n            github_repo_id: 1,\n            owner: \"octo\".to_owned(),\n            repo: \"demo\".to_owned(),\n            number,\n            title: \"t\".to_owned(),\n            base_ref: \"main\".to_owned(),\n            head_ref: \"feature\".to_owned(),\n            head_sha: head_sha.to_owned(),\n            source_url: \"https://example.invalid\".to_owned(),\n        }\n    }\n\n    fn projection() -> Arc<ProjectionOutcome> {\n        Arc::new(ProjectionOutcome::NoMatches)\n    }\n\n    #[test]\n    fn key_changes_when_metadata_oid_changes() {\n        let pr = pr_facts(1, \"sha\");\n        assert_ne!(\n            SnapshotKey::new(&pr, \"oid-a\"),\n            SnapshotKey::new(&pr, \"oid-b\"),\n            \"a new metadata OID must not reuse a prior snapshot\"\n        );\n    }\n\n    #[test]\n    fn key_changes_when_pr_head_moves() {\n        assert_ne!(\n            SnapshotKey::new(&pr_facts(1, \"sha-old\"), \"oid\"),\n            SnapshotKey::new(&pr_facts(1, \"sha-new\"), \"oid\"),\n        );\n    }\n\n    #[test]\n    fn identical_inputs_hit_the_same_entry() {\n        let cache = SnapshotCache::default();\n        let pr = pr_facts(7, \"sha\");\n        cache.insert(SnapshotKey::new(&pr, \"oid\"), projection());\n\n        assert!(cache.get(&SnapshotKey::new(&pr, \"oid\")).is_some());\n        assert!(\n            cache.get(&SnapshotKey::new(&pr, \"other-oid\")).is_none(),\n            \"a different OID must miss\"\n        );\n    }\n}\n","tool_name":"exec_command","tool_kind":"exec","tool_input":null,"exit_code":0,"outcome":"succeeded","source_record":{"timestamp":"2026-05-26T11:32:10.007Z","type":"response_item","payload":{"type":"function_call_output","call_id":"[REDACTED:entropy]"}}}