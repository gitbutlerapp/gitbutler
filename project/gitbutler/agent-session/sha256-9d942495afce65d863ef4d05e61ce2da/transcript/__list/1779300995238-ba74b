'value'], r['timestamp']))\n    return out\n\ndef j(s):\n    return json.loads(s)\n\ndef trunc_text(v, n=90):\n    if isinstance(v, str):\n        return ' '.join(v.split())[:n]\n    return ''\n\n# index health\n# reproduce index_key? easier: find metadata keys with branch index prefix and inspect candidates containing target? Print likely keys/counts.\nindex_rows = con.execute(\"select rowid,key,value_type from metadata where target_type='project' and key like 'gitbutler:agentlog:index:branch:%'\").fetchall()\nprint('branch index metadata rows:', len(index_rows))\nfor row in index_rows:\n    vals = set_values(row['key'])\n    hits = []\n    for _, val, _ in vals:\n        try:\n            hit = json.loads(val)\n        except Exception:\n            continue\n        if hit.get('session_key') in sessions:\n            hits.append(hit)\n    if hits:\n        print('index', row['key'], 'hits_for_returned_sessions', len(hits), 'total_hits', len(vals))\n\nprint('\\nreturned sessions:')\nfor sk in sessions:\n    prefix = f'gitbutler:agent-session:{sk}'\n    updated = value_for_row(md(f'{prefix}:updated-at'))\n    source_keys = [m for m,_,_ in set_values(f'{prefix}:sources')]\n    turns = [j(v) for v,_ in list_values(f'{prefix}:turns')]\n    records = [j(v) for v,_ in list_values(f'{prefix}:transcript')]\n    first_ts = records[0].get('timestamp') if records else None\n    last_ts = records[-1].get('timestamp') if records else None\n    first_user = next((trunc_text(r.get('content')) for r in records if r.get('role') == 'user' and r.get('content')), '')\n    print(f'- {sk}')\n    print(f'  updated_at={updated} sources={len(source_keys)} records={len(records)} turns={len(turns)} first_record={first_ts} last_record={last_ts}')\n    if source_keys:\n        sp = f'{prefix}:source:{source_keys[0]}'\n        agent = value_for_row(md(f'{sp}:agent'))\n        provider = value_for_row(md(f'{sp}:provider'))\n        model = value_for_row(md(f'{sp}:model'))\n        tool = value_for_row(md(f'{sp}:tool-version'))\n        print(f'  source={source_keys[0]} agent={agent} provider={provider} model={model} tool={tool}')\n    print(f'  first_user={first_user}')\n    prev_ok = True\n    target_turns = []\n    for i,t in enumerate(turns):\n        tk = t.get('turn_key')\n        detail_s = value_for_row(md(f'{prefix}:turn:{tk}'))\n        detail = j(detail_s)\n        branches = detail.get('observed_targets',{}).get('branches') or []\n        observes = any(b.get('key') == target_key for b in branches)\n        if observes:\n            target_turns.append(tk)\n        expected_prev = turns[i-1].get('turn_key') if i else None\n        if t.get('previous_turn_key') != expected_prev:\n            prev_ok = False\n        rec_count = len(detail.get('records') or [])\n        env_status = t.get('environment_snapshot_status')\n        print(f'  turn {i+1}: {tk} kind={t.get(\"capture_kind\")} captured={t.get(\"captured_at\")} records={rec_count} observes_branch={observes} env={env_status} prev_ok={t.get(\"previous_turn_key\") == expected_prev}')\n    print(f'  target_turns={len(target_turns)} previous_chain_ok={prev_ok}')\nPY","workdir":"/Users/kiril/src/gitbutler","yield_time_ms":1000,"max_output_tokens":60000},"source_record":{"timestamp":"2026-05-20T18:14:55.283Z","type":"response_item","payload":{"type":"function_call","name":"exec_command","call_id":"[REDACTED:entropy]"}}}