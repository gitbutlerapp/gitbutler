 session count:', len(setvals('gitbutler:agent-sessions')))\nfor r in con.execute(\"select key from metadata where target_type='project' and target_value='' and key like 'gitbutler:agentlog-index:v1:branch:%' order by key\"):\n    vals = setvals(r['key'])\n    hits = []\n    for v in vals:\n        if isinstance(v, str):\n            try: v = json.loads(v)\n            except: pass\n        if isinstance(v, dict): hits.append(v)\n    print('branch-index-key', r['key'].split(':')[-1], 'total_hits', len(hits), 'returned_session_hits', sum(1 for h in hits if h.get('session_key') in sessions))\n\nprint('\\nsession summary:')\nfor sk in sessions:\n    prefix = f'gitbutler:agent-session:{sk}'\n    sources = setvals(f'{prefix}:sources')\n    turns = listvals(f'{prefix}:turns')\n    records = listvals(f'{prefix}:transcript')\n    print(f'\\n{sk}')\n    print('  updated_at:', mdval(f'{prefix}:updated-at'), 'sources:', ','.join(sources), 'records:', len(records), 'turns:', len(turns))\n    for source in sources:\n        sp = f'{prefix}:source:{source}'\n        print('  source_meta:', mdval(f'{sp}:agent'), mdval(f'{sp}:provider'), mdval(f'{sp}:model'), mdval(f'{sp}:tool-version'))\n    first_user = next((r for r in records if isinstance(r, dict) and r.get('role') == 'user' and r.get('text')), None)\n    last_user = next((r for r in reversed(records) if isinstance(r, dict) and r.get('role') == 'user' and r.get('text')), None)\n    print('  first_user:', short(first_user.get('text') if first_user else ''))\n    print('  last_user:', short(last_user.get('text') if last_user else ''))\n    observed = 0\n    counts = []\n    for i,t in enumerate(turns):\n        detail = mdval(f'{prefix}:turn:{t[\"turn_key\"]}')\n        branches = detail.get('observed_targets',{}).get('branches') or []\n        hit = any(b.get('key') == target_key for b in branches)\n        observed += hit\n        counts.append(len(detail.get('records') or []))\n    print('  turn_record_counts:', counts)\n    