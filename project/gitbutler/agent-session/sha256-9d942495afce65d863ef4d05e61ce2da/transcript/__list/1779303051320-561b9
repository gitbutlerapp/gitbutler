ge/current session for detailed view.\nmain=max(reports, key=lambda r: r['records']) if reports else None\nprint('\\nDETAILED LARGEST SESSION')\nif main:\n    print(f\"session={main['session']} turns={main['turns']} records={main['records']} updated={main['updated']}\")\n    for tr in main['turn_reports']:\n        print(f\"[{tr['i']:02}] {tr['turn'][:19]}… {tr['capture_kind']} at={tr['captured_at']} records={tr['record_count']} idx={tr['idx_range']} env={tr['env_status']} wt={tr['worktree_count']}{' trunc' if tr['worktree_truncated'] else ''}\")\n        print(f\"     kinds={tr['kinds']} tools={tr['top_tools']} missing={tr['missing_records']}\")\n        if tr['targets']: print(f\"     targets={tr['targets']}\")\n        if tr['latest_user']: print(f\"     user={tr['latest_user']}\")\n        if tr['latest_assistant']: print(f\"     asst={tr['latest_assistant']}\")\n\n# verify branch index value format and observed branch relation\nprint('\\nBRANCH INDEX VALUES')\nfor k in branch_idx_keys:\n    vals=set_values(k)\n    print(k, 'count', len(vals), 'sample', vals[:3])\nPY","yield_time_ms":1000,"max_output_tokens":40000,"workdir":"/Users/kiril/src/gitbutler"},"source_record":{"timestamp":"2026-05-20T18:49:46.978Z","type":"response_item","payload":{"type":"function_call","name":"exec_command","call_id":"[REDACTED:entropy]"}}}