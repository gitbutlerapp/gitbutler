{"source_key":"sha256-c55db1afbbe5d9067606af4f013482ee","record_index":212,"record_hash":"sha256:d08cc485ab800cab08ca25e6c47c6bd46a7cbb3e04a9011647aed3eadd8e91cd","timestamp":"2026-05-31T12:32:38.873Z","kind":"tool_call","source_event_kind":"codex:response_item:custom_tool_call","role":null,"text":null,"tool_name":"apply_patch","tool_kind":"file_edit","tool_input":"*** Begin Patch\n*** Add File: [REDACTED:path]\n+use std::collections::BTreeSet;\n+\n+use rusqlite::{params, OptionalExtension};\n+\n+use crate::{\n+    error::{Error, Result},\n+    types::{MetaMove, MoveStats, Target, ValueType, validate_key},\n+};\n+\n+use super::{Store, COLLECTION_LOG_VALUE, escape_like_pattern, types::Operation};\n+\n+#[derive(Debug)]\n+struct KeyMoveRow {\n+    rowid: i64,\n+    source_key: String,\n+    destination_key: String,\n+    value: String,\n+    value_type: ValueType,\n+}\n+\n+impl Store {\n+    /// Apply metadata moves in one transaction.\n+    ///\n+    /// Prefix moves rename metadata rows in-place, preserving list/set backing\n+    /// rows. Set-member moves add the requested members to the destination set\n+    /// and remove them from the source set in the same savepoint.\n+    pub fn apply_moves<'a>(\n+        &self,\n+        target: &Target,\n+        moves: impl IntoIterator<Item = MetaMove<'a>>,\n+        email: &str,\n+        timestamp: i64,\n+    ) -> Result<MoveStats> {\n+        let moves = moves.into_iter().collect::<Vec<_>>();\n+        for move_op in &moves {\n+            match move_op {\n+                MetaMove::KeyPrefix {\n+                    source_prefix,\n+                    destination_prefix,\n+                } => {\n+                    validate_prefix_move(source_prefix, destination_prefix)?;\n+                }\n+                MetaMove::SetMembers {\n+                    source_key,\n+                    destination_key,\n+                    members: _,\n+                } => {\n+                    validate_key(source_key)?;\n+                    validate_key(destination_key)?;\n+                    if source_key == destination_key {\n+                        return Err(Error::InvalidKey(\n+                            \"source and destination set keys must differ\".into(),\n+                        ));\n+                    }\n+                }\n+            }\n+        }\n+\n+        let sp = self.savepoint()?;\n+        let mut stats = MoveStats::default();\n+        for move_op in moves {\n+            match move_op {\n+                MetaMove::KeyPrefix {\n+                    source_prefix,\n+                    destination_prefix,\n+                } => {\n+                    stats.keys += self.move_key_prefix_tx(\n+                        target,\n+                        source_prefix,\n+                        destination_prefix,\n+                        email,\n+                        timestamp,\n+                    )?;\n+                }\n+                MetaMove::SetMembers {\n+                    source_key,\n+                    destination_key,\n+                    members,\n+                } => {\n+                    stats.set_members += self.move_set_members_tx(\n+                        target,\n+                        source_key,\n+                        destination_key,\n+                        members,\n+                        email,\n+                        timestamp,\n+                    )?;\n+                }\n+            }\n+        }\n+        sp.commit()?;\n+        Ok(stats)\n+    }\n+\n+    fn move_key_prefix_tx(\n+        &self,\n+        target: &Target,\n+        source_prefix: &str,\n+        destination_prefix: &str,\n+        email: &str,\n+        timestamp: i64,\n+    ) -> Result<usize> {\n+        let target_type = target.target_type().as_str();\n+        let target_value = target.value().unwrap_or(\"\");\n+        let rows = self.key_move_rows(target_type, target_value, source_prefix, destination_prefix)?;\n+        if rows.is_empty() {\n+            return Ok(0);\n+        }\n+\n+        let mut destination_keys = BTreeSet::new();\n+        for row in &rows {\n+            if !destination_keys.insert(row.destination_key.clone()) {\n+                return Err(Error::InvalidValue(format!(\n+                    \"move would create duplicate destination key '{}'\",\n+                    row.destination_key\n+                )));\n+            }\n+            let existing_rowid = self\n+                .conn\n+                .query_row(\n+                    \"SELECT rowid FROM metadata\n+                     WHERE target_type = ?1 AND target_value = ?2 AND key = ?3\",\n+                    params![target_type, target_value, row.destination_key],\n+                    |row| row.get::<_, i64>(0),\n+                )\n+                .optional()?;\n+            if existing_rowid.is_some_and(|rowid| rowid != row.rowid) {\n+                return Err(Error::InvalidValue(format!(\n+                    \"destination key '{}' already exists\",\n+                    row.destination_key\n+                )));\n+            }\n+        }\n+\n+        for row in &rows {\n+            self.conn.execute(\n+                \"UPDATE metadata\n+                 SET key = ?1, last_timestamp = ?2, is_promised = 0\n+                 WHERE rowid = ?3\",\n+                params![row.destination_key, timestamp, row.rowid],\n+            )?;\n+            self.conn.execute(\n+                \"UPDATE tombstones\n+                 SET key = ?1\n+                 WHERE target_type = ?2 AND target_value = ?3 AND key = ?4\",\n+                params![\n+                    row.destination_key,\n+                    target_type,\n+                    target_value,\n+                    row.source_key\n+                ],\n+            )?;\n+            self.conn.execute(\n+                \"DELETE FROM tombstones\n+                 WHERE tombstone_type = 'metadata'\n+                 AND target_type = ?1 AND target_value = ?2 AND key = ?3\",\n+                params![target_type, target_value, row.destination_key],\n+            )?;\n+            self.conn.execute(\n+                \"INSERT INTO tombstones (tombstone_type, target_type, target_value, key, entry_id, value, timestamp, email)\n+                 VALUES ('metadata', ?1, ?2, ?3, '', '', ?4, ?5)\n+                 ON CONFLICT(tombstone_type, target_type, target_value, key, entry_id) DO UPDATE\n+                 SET timestamp = excluded.timestamp, email = excluded.email\",\n+                params![target_type, target_value, row.source_key, timestamp, email],\n+            )?;\n+            self.conn.execute(\n+                \"INSERT INTO metadata_log (target_type, target_value, key, value, value_type, operation, email, timestamp)\n+                 VALUES (?1, ?2, ?3, '', '', ?4, ?5, ?6)\",\n+                params![\n+                    target_type,\n+                    target_value,\n+                    row.source_key,\n+                    Operation::Remove.as_str(),\n+                    email,\n+                    timestamp\n+                ],\n+            )?;\n+            let log_value = match row.value_type {\n+                ValueType::String => row.value.as_str(),\n+                ValueType::List | ValueType::Set => COLLECTION_LOG_VALUE,\n+            };\n+            self.conn.execute(\n+                \"INSERT INTO metadata_log (target_type, target_value, key, value, value_type, operation, email, timestamp)\n+                 VALUES (?1, ?2, ?3, ?4, ?5, ?6, ?7, ?8)\",\n+                params![\n+                    target_type,\n+                    target_value,\n+                    row.destination_key,\n+                    log_value,\n+                    row.value_type.as_str(),\n+                    Operation::Set.as_str(),\n+                    email,\n+                    timestamp\n+                ],\n+            )?;\n+        }\n+\n+        Ok(rows.len())\n+    }\n+\n+    fn key_move_rows(\n+        &self,\n+        target_type: &str,\n+        target_value: &str,\n+        source_prefix: &str,\n+        destination_prefix: &str,\n+    ) -> Result<Vec<KeyMoveRow>> {\n+        let source_like = format!(\"{}:%\", escape_like_pattern(source_prefix));\n+        let mut stmt = self.conn.prepare(\n+            \"SELECT rowid, key, value, value_type\n+             FROM metadata\n+             WHERE target_type = ?1 AND target_value = ?2\n+             AND (key = ?3 OR key LIKE ?4 ESCAPE '\\\\')\n+             ORDER BY key\",\n+        )?;\n+        let rows = stmt.query_map(\n+            params![target_type, target_value, source_prefix, source_like],\n+            |row| {\n+                Ok((\n+                    row.get::<_, i64>(0)?,\n+                    row.get::<_, String>(1)?,\n+                    row.get::<_, String>(2)?,\n+                    row.get::<_, String>(3)?,\n+                ))\n+            },\n+        )?;\n+\n+        let mut move_rows = Vec::new();\n+        for row in rows {\n+            let (rowid, source_key, value, value_type) = row?;\n+            let suffix = source_key\n+                .strip_prefix(source_prefix)\n+                .ok_or_else(|| Error::InvalidKey(format!(\"key '{source_key}' is outside move prefix\")))?;\n+            let destination_key = format!(\"{destination_prefix}{suffix}\");\n+            move_rows.push(KeyMoveRow {\n+                rowid,\n+                source_key,\n+                destination_key,\n+                value,\n+                value_type: value_type.parse()?,\n+            });\n+        }\n+        Ok(move_rows)\n+    }\n+\n+    fn move_set_members_tx(\n+        &self,\n+        target: &Target,\n+        source_key: &str,\n+        destination_key: &str,\n+        members: &[String],\n+        email: &str,\n+        timestamp: i64,\n+    ) -> Result<usize> {\n+        if members.is_empty() {\n+            return Ok(0);\n+        }\n+        self.add_set_members(target, destination_key, members, email, timestamp)?;\n+        for member in members {\n+            self.set_remove(target, source_key, member, email, timestamp)?;\n+        }\n+        Ok(members.len())\n+    }\n+}\n+\n+fn validate_prefix_move(source_prefix: &str, destination_prefix: &str) -> Result<()> {\n+    validate_key(source_prefix)?;\n+    validate_key(destination_prefix)?;\n+    if source_prefix == destination_prefix {\n+        return Err(Error::InvalidKey(\n+            \"source and destination prefixes must differ\".into(),\n+        ));\n+    }\n+    if is_key_namespace_prefix(source_prefix, destination_prefix)\n+        || is_key_namespace_prefix(destination_prefix, source_prefix)\n+    {\n+        return Err(Error::InvalidKey(\n+            \"source and destination prefixes must not overlap\".into(),\n+        ));\n+    }\n+    Ok(())\n+}\n+\n+fn is_key_namespace_prefix(prefix: &str, key: &str) -> bool {\n+    key.strip_prefix(prefix)\n+        .is_some_and(|suffix| suffix.starts_with(':'))\n+}\n*** End Patch\n","source_record":{"timestamp":"2026-05-31T12:32:38.873Z","type":"response_item","payload":{"type":"custom_tool_call","status":"completed","call_id":"[REDACTED:entropy]","name":"apply_patch"}}}