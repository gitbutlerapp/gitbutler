{"source_key":"sha256-67ab078c7f660fb9364b7c83113ccb67","record_index":922,"record_hash":"sha256:f0cedef064795ea82d1167b8d36b647a1acf9a89f32ff470499fa5bf9267d2ca","timestamp":"2026-06-04T19:38:57.147Z","kind":"tool_call","source_event_kind":"codex:response_item:function_call","role":null,"text":null,"tool_name":"exec","tool_kind":"other","tool_input":{"command":"call execute-sql {\"query\":\"WITH version_bounds AS (\\n    SELECT\\n        toString(properties.appVersion) AS app_version,\\n        min(timestamp) AS start_ts\\n    FROM events\\n    WHERE timestamp >= now() - INTERVAL 30 DAY\\n      AND toString(properties.appVersion) IN ('0.20.0', '0.19.13')\\n    GROUP BY app_version\\n), elapsed AS (\\n    SELECT dateDiff('second', start_ts, now()) AS elapsed_seconds\\n    FROM version_bounds\\n    WHERE app_version = '0.20.0'\\n), filtered AS (\\n    SELECT\\n        toString(e.properties.appVersion) AS app_version,\\n        e.timestamp AS timestamp,\\n        nullIf(toString(e.properties.$session_id), '') AS session_id,\\n        coalesce(nullIf(toString(e.person_id), '[REDACTED:entropy]'), e.distinct_id) AS user_id,\\n        lower(toString(e.person.properties.email)) AS email,\\n        toString(e.properties.error) AS raw_error\\n    FROM events e\\n    INNER JOIN version_bounds b ON toString(e.properties.appVersion) = b.app_version\\n    CROSS JOIN elapsed\\n    WHERE e.timestamp >= b.start_ts\\n      AND e.timestamp < b.start_ts + INTERVAL elapsed.elapsed_seconds SECOND\\n      AND toString(e.properties.appVersion) IN ('0.20.0', '0.19.13')\\n      AND e.event = 'Create Virtual Branch From Branch Failed'\\n), clean AS (\\n    SELECT *\\n    FROM filtered\\n    WHERE email = ''\\n       OR (email NOT LIKE '%@gitbutler.com'\\n           AND email NOT IN (\\n               'donahue.ian@gmail.com', 'mtsgrd@gmail.com', 'leuschneranne@gmail.com', 'schacon@gmail.com',\\n               'kiril@videlov.com', 'nikita@galaiko.rocks', 'pawellaptew@gmail.com', 'nico@gitbutler.com',\\n               'hello@calebowens.com', 'stron@me.com', 'h1ghbre4k3r@dev.bre4k3r.de', 'caleb@gitbutler.com'\\n           ))\\n), bucketed AS (\\n    SELECT\\n        app_version,\\n        multiIf(\\n            raw_error LIKE '%GitButler workspace commit not found%', 'workspace commit not found',\\n            raw_error LIKE '%workspace commit isn%' OR raw_error LIKE '%workspace commit not%' OR raw_error LIKE '%Repo HEAD is unavailable%' OR raw_error LIKE '%Please checkout gitbutler/workspace%', 'workspace/ref state invalid',\\n            raw_error LIKE '%Uncommitted files would be overwritten by checkout%' OR raw_error LIKE '%Worktree changes would be overwritten by checkout%', 'checkout would overwrite local files',\\n            raw_error LIKE '%os error 32%' OR raw_error LIKE '%used by another process%' OR raw_error LIKE '%używany przez inny proces%', 'file locked / used by another process',\\n            raw_error LIKE '%Incorrect function. (os error 1)%', 'windows incorrect function',\\n            raw_error LIKE '%disjoint in the commit-graph%' OR raw_error LIKE '%find merge-base%', 'disjoint commit graph / merge-base',\\n            raw_error LIKE '%index is locked%', 'git index locked',\\n            raw_error LIKE '%Permission denied%' OR raw_error LIKE '%Access is denied%', 'permission denied',\\n            'other'\\n        ) AS bucket,\\n        user_id,\\n        session_id\\n    FROM clean\\n)\\nSELECT\\n    app_version,\\n    bucket,\\n    count() AS events,\\n    uniqExact(user_id) AS users,\\n    uniqExact(session_id) AS sessions\\nFROM bucketed\\nGROUP BY app_version, bucket\\nORDER BY app_version DESC, events DESC\\nLIMIT 100\", \"truncate\": true}"},"source_record":{"timestamp":"2026-06-04T19:38:57.147Z","type":"response_item","payload":{"type":"function_call","name":"exec","namespace":"mcp__posthog","call_id":"[REDACTED:entropy]"}}}