{"source_key":"sha256-67ab078c7f660fb9364b7c83113ccb67","record_index":1119,"record_hash":"sha256:83447ebe9d62dae6967e017c2138b8d8d245ced2f1eb71769f5b9ed3e2eee5c3","timestamp":"2026-06-05T21:18:16.731Z","kind":"tool_call","source_event_kind":"codex:response_item:function_call","role":null,"text":null,"tool_name":"exec","tool_kind":"other","tool_input":{"command":"call execute-sql {\"query\":\"WITH base AS (\\n    SELECT\\n        toString(properties.appVersion) AS app_version,\\n        event,\\n        timestamp,\\n        nullIf(toString(properties.$session_id), '') AS session_id,\\n        coalesce(nullIf(toString(person_id), '[REDACTED:entropy]'), distinct_id) AS user_id,\\n        lower(toString(person.properties.email)) AS email\\n    FROM events\\n    WHERE timestamp >= now() - INTERVAL 45 DAY\\n      AND toString(properties.appVersion) IN ('0.20.0', '0.19.13')\\n), clean AS (\\n    SELECT *\\n    FROM base\\n    WHERE email = ''\\n       OR (email NOT LIKE '%@gitbutler.com'\\n           AND email NOT IN (\\n               'donahue.ian@gmail.com', 'mtsgrd@gmail.com', 'leuschneranne@gmail.com', 'schacon@gmail.com',\\n               'kiril@videlov.com', 'nikita@galaiko.rocks', 'pawellaptew@gmail.com', 'nico@gitbutler.com',\\n               'hello@calebowens.com', 'stron@me.com', 'h1ghbre4k3r@dev.bre4k3r.de', 'caleb@gitbutler.com'\\n           ))\\n), scored AS (\\n    SELECT\\n        *,\\n        (event = 'query:error'\\n         OR event = 'toast:show_error'\\n         OR event ILIKE '% Failed'\\n         OR event ILIKE '% Failure'\\n         OR event ILIKE '% Error') AS is_errorish,\\n        event = '$exception' AS is_exception\\n    FROM clean\\n)\\nSELECT\\n    app_version,\\n    min(timestamp) AS first_seen,\\n    max(timestamp) AS last_seen,\\n    count() AS total_events,\\n    uniqExact(user_id) AS users,\\n    uniqExact(session_id) AS sessions,\\n    countIf(is_errorish) AS error_events,\\n    uniqExactIf(user_id, is_errorish) AS error_users,\\n    uniqExactIf(session_id, is_errorish) AS error_sessions,\\n    round(100.0 * error_events / nullIf(total_events, 0), 3) AS error_event_rate_pct,\\n    round(100.0 * error_users / nullIf(users, 0), 2) AS error_user_rate_pct,\\n    countIf(is_exception) AS exception_events,\\n    uniqExactIf(user_id, is_exception) AS exception_users\\nFROM scored\\nGROUP BY app_version\\nORDER BY app_version DESC\\nLIMIT 100\", \"truncate\": true}"},"source_record":{"timestamp":"2026-06-05T21:18:16.731Z","type":"response_item","payload":{"type":"function_call","name":"exec","namespace":"mcp__posthog","call_id":"[REDACTED:entropy]"}}}