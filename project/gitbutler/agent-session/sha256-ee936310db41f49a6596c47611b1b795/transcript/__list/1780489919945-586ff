{"source_key":"sha256-67ab078c7f660fb9364b7c83113ccb67","record_index":173,"record_hash":"sha256:6e83111163ab13cc18295e2effd246b0c28e27d64ad4ad36df0ddc0e0a488ba5","timestamp":"2026-06-03T12:28:56.516Z","kind":"tool_call","source_event_kind":"codex:response_item:function_call","role":null,"text":null,"tool_name":"exec","tool_kind":"other","tool_input":{"command":"call execute-sql {\"query\":\"WITH base AS (SELECT properties.appVersion AS app_version, timestamp, coalesce(nullIf(toString(person_id), '[REDACTED:entropy]'), distinct_id) AS user_id, properties.error_title AS error_title, left(replaceRegexpAll(toString(properties.error_message), '[0-9a-f]{7,40}|/[A-Za-z0-9_./ -]+', '<redacted>'), 220) AS message_key FROM events WHERE timestamp >= now() - INTERVAL 30 DAY AND properties.appVersion IN ('0.20.0', '0.19.13') AND event = 'toast:show_error') SELECT error_title, message_key, countIf(app_version = '0.20.0') AS v020_events, count(DISTINCT if(app_version = '0.20.0', user_id, NULL)) AS v020_users, countIf(app_version = '0.19.13') AS v019_events, count(DISTINCT if(app_version = '0.19.13', user_id, NULL)) AS v019_users, minIf(timestamp, app_version = '0.20.0') AS v020_first_seen, maxIf(timestamp, app_version = '0.20.0') AS v020_last_seen FROM base GROUP BY error_title, message_key HAVING v020_events > 0 ORDER BY v020_events DESC, v020_users DESC, v019_events ASC LIMIT 100\",\"truncate\":true}"},"source_record":{"timestamp":"2026-06-03T12:28:56.516Z","type":"response_item","payload":{"type":"function_call","name":"exec","namespace":"mcp__posthog","call_id":"[REDACTED:entropy]"}}}