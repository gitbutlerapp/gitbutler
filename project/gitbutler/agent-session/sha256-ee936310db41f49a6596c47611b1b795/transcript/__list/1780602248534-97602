{"source_key":"sha256-67ab078c7f660fb9364b7c83113ccb67","record_index":988,"record_hash":"sha256:1d506232f258d98c0a291dad058460b6d0fa0ca10a71f92fd52f8edb715686bd","timestamp":"2026-06-04T19:41:36.795Z","kind":"tool_call","source_event_kind":"codex:response_item:function_call","role":null,"text":null,"tool_name":"exec","tool_kind":"other","tool_input":{"command":"call execute-sql {\"query\":\"WITH base AS (\\n    SELECT\\n        event,\\n        timestamp,\\n        nullIf(toString(properties.$session_id), '') AS session_id,\\n        coalesce(nullIf(toString(person_id), '[REDACTED:entropy]'), distinct_id) AS user_id,\\n        lower(toString(person.properties.email)) AS email,\\n        toString(properties.appVersion) AS app_version,\\n        nullIf(toString(properties.command), '') AS command,\\n        lower(concat(\\n            ' ', toString(properties.error),\\n            ' ', toString(properties.error_title),\\n            ' ', toString(properties.error_message),\\n            ' ', toString(properties.message),\\n            ' ', toString(properties.title),\\n            ' ', toString(issue_name),\\n            ' ', toString(issue_description)\\n        )) AS message_blob\\n    FROM events\\n    WHERE timestamp >= now() - INTERVAL 30 DAY\\n      AND (event = 'query:error'\\n           OR event = 'toast:show_error'\\n           OR event = '$exception'\\n           OR lower(event) LIKE '% failed'\\n           OR lower(event) LIKE '% failure'\\n           OR lower(event) LIKE '% error'\\n           OR lower(event) LIKE '%_failed')\\n), clean AS (\\n    SELECT *\\n    FROM base\\n    WHERE email = ''\\n       OR (email NOT LIKE '%@gitbutler.com'\\n           AND email NOT IN (\\n               'donahue.ian@gmail.com', 'mtsgrd@gmail.com', 'leuschneranne@gmail.com', 'schacon@gmail.com',\\n               'kiril@videlov.com', 'nikita@galaiko.rocks', 'pawellaptew@gmail.com', 'nico@gitbutler.com',\\n               'hello@calebowens.com', 'stron@me.com', 'h1ghbre4k3r@dev.bre4k3r.de', 'caleb@gitbutler.com'\\n           ))\\n), scored AS (\\n    SELECT\\n        *,\\n        message_blob LIKE '%would be overwritten by checkout%' AS is_overwrite_checkout\\n    FROM clean\\n)\\nSELECT\\n    min(timestamp) AS first_seen,\\n    max(timestamp) AS last_seen,\\n    count() AS errorish_events,\\n    uniqExact(user_id) AS errorish_users,\\n    uniqExact(session_id) AS errorish_sessions,\\n    countIf(is_overwrite_checkout) AS overwrite_events,\\n    uniqExactIf(user_id, is_overwrite_checkout) AS overwrite_users,\\n    uniqExactIf(session_id, is_overwrite_checkout) AS overwrite_sessions,\\n    round(100.0 * overwrite_events / nullIf(errorish_events, 0), 2) AS share_of_error_events_pct,\\n    round(100.0 * overwrite_users / nullIf(errorish_users, 0), 2) AS share_of_error_users_pct,\\n    round(100.0 * overwrite_sessions / nullIf(errorish_sessions, 0), 2) AS share_of_error_sessions_pct\\nFROM scored\\nLIMIT 100\", \"truncate\": true}"},"source_record":{"timestamp":"2026-06-04T19:41:36.795Z","type":"response_item","payload":{"type":"function_call","name":"exec","namespace":"mcp__posthog","call_id":"[REDACTED:entropy]"}}}