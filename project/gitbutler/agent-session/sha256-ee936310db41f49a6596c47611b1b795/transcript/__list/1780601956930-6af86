{"source_key":"sha256-67ab078c7f660fb9364b7c83113ccb67","record_index":847,"record_hash":"sha256:95d437f9797baf3a9e56b040e861fa566b3f7fbcc356579bca3f15dba6446565","timestamp":"2026-06-04T19:36:29.119Z","kind":"tool_call","source_event_kind":"codex:response_item:function_call","role":null,"text":null,"tool_name":"exec","tool_kind":"other","tool_input":{"command":"call execute-sql {\"query\":\"WITH filtered AS (\\n    SELECT\\n        toString(properties.appVersion) AS app_version,\\n        event,\\n        timestamp,\\n        nullIf(toString(properties.$session_id), '') AS session_id,\\n        coalesce(nullIf(toString(person_id), '[REDACTED:entropy]'), distinct_id) AS user_id,\\n        lower(toString(person.properties.email)) AS email\\n    FROM events\\n    WHERE timestamp >= now() - INTERVAL 30 DAY\\n      AND toString(properties.appVersion) IN ('0.20.0', '0.19.13')\\n      AND event IN ('Create Virtual Branch From Branch Successful', 'Create Virtual Branch From Branch Failed')\\n), clean AS (\\n    SELECT *\\n    FROM filtered\\n    WHERE email = ''\\n       OR (email NOT LIKE '%@gitbutler.com'\\n           AND email NOT IN (\\n               'donahue.ian@gmail.com', 'mtsgrd@gmail.com', 'leuschneranne@gmail.com', 'schacon@gmail.com',\\n               'kiril@videlov.com', 'nikita@galaiko.rocks', 'pawellaptew@gmail.com', 'nico@gitbutler.com',\\n               'hello@calebowens.com', 'stron@me.com', 'h1ghbre4k3r@dev.bre4k3r.de', 'caleb@gitbutler.com'\\n           ))\\n)\\nSELECT\\n    app_version,\\n    min(timestamp) AS first_seen,\\n    max(timestamp) AS last_seen,\\n    countIf(event = 'Create Virtual Branch From Branch Successful') AS success_events,\\n    countIf(event = 'Create Virtual Branch From Branch Failed') AS failure_events,\\n    count() AS attempt_events,\\n    round(100.0 * failure_events / nullIf(attempt_events, 0), 2) AS failure_event_rate_pct,\\n    uniqExactIf(user_id, event = 'Create Virtual Branch From Branch Successful') AS success_users,\\n    uniqExactIf(user_id, event = 'Create Virtual Branch From Branch Failed') AS failure_users,\\n    uniqExact(user_id) AS attempt_users,\\n    round(100.0 * failure_users / nullIf(attempt_users, 0), 2) AS failure_user_rate_pct,\\n    uniqExactIf(session_id, event = 'Create Virtual Branch From Branch Failed') AS failure_sessions\\nFROM clean\\nGROUP BY app_version\\nORDER BY app_version DESC\", \"truncate\": true}"},"source_record":{"timestamp":"2026-06-04T19:36:29.119Z","type":"response_item","payload":{"type":"function_call","name":"exec","namespace":"mcp__posthog","call_id":"[REDACTED:entropy]"}}}