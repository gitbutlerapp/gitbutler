{"source_key":"sha256-67ab078c7f660fb9364b7c83113ccb67","record_index":1132,"record_hash":"sha256:1cabc9b982718623a5e8d0b3323d88860d0241b94a9c8675779f137176ee0277","timestamp":"2026-06-05T21:18:37.243Z","kind":"tool_call","source_event_kind":"codex:response_item:function_call","role":null,"text":null,"tool_name":"exec","tool_kind":"other","tool_input":{"command":"call execute-sql {\"query\":\"WITH version_bounds AS (\\n    SELECT\\n        toString(properties.appVersion) AS app_version,\\n        min(timestamp) AS start_ts\\n    FROM events\\n    WHERE timestamp >= now() - INTERVAL 45 DAY\\n      AND toString(properties.appVersion) IN ('0.20.0', '0.19.13')\\n    GROUP BY app_version\\n), elapsed AS (\\n    SELECT dateDiff('second', start_ts, now()) AS elapsed_seconds\\n    FROM version_bounds\\n    WHERE app_version = '0.20.0'\\n), base AS (\\n    SELECT\\n        toString(e.properties.appVersion) AS app_version,\\n        e.event AS event,\\n        e.timestamp AS timestamp,\\n        nullIf(toString(e.properties.$session_id), '') AS session_id,\\n        coalesce(nullIf(toString(e.person_id), '[REDACTED:entropy]'), e.distinct_id) AS user_id,\\n        lower(toString(e.person.properties.email)) AS email,\\n        b.start_ts AS version_start\\n    FROM events e\\n    INNER JOIN version_bounds b ON toString(e.properties.appVersion) = b.app_version\\n    CROSS JOIN elapsed\\n    WHERE e.timestamp >= b.start_ts\\n      AND e.timestamp < b.start_ts + INTERVAL elapsed.elapsed_seconds SECOND\\n      AND toString(e.properties.appVersion) IN ('0.20.0', '0.19.13')\\n), clean AS (\\n    SELECT *\\n    FROM base\\n    WHERE email = ''\\n       OR (email NOT LIKE '%@gitbutler.com'\\n           AND email NOT IN (\\n               'donahue.ian@gmail.com', 'mtsgrd@gmail.com', 'leuschneranne@gmail.com', 'schacon@gmail.com',\\n               'kiril@videlov.com', 'nikita@galaiko.rocks', 'pawellaptew@gmail.com', 'nico@gitbutler.com',\\n               'hello@calebowens.com', 'stron@me.com', 'h1ghbre4k3r@dev.bre4k3r.de', 'caleb@gitbutler.com'\\n           ))\\n), scored AS (\\n    SELECT\\n        *,\\n        (event = 'query:error'\\n         OR event = 'toast:show_error'\\n         OR event ILIKE '% Failed'\\n         OR event ILIKE '% Failure'\\n         OR event ILIKE '% Error') AS is_errorish\\n    FROM clean\\n)\\nSELECT\\n    app_version,\\n    min(version_start) AS version_start,\\n    min(timestamp) AS first_seen_in_window,\\n    max(timestamp) AS last_seen_in_window,\\n    count() AS total_events,\\n    uniqExact(user_id) AS users,\\n    uniqExact(session_id) AS sessions,\\n    countIf(is_errorish) AS error_events,\\n    uniqExactIf(user_id, is_errorish) AS error_users,\\n    uniqExactIf(session_id, is_errorish) AS error_sessions,\\n    round(100.0 * error_events / nullIf(total_events, 0), 3) AS error_event_rate_pct,\\n    round(100.0 * error_users / nullIf(users, 0), 2) AS error_user_rate_pct\\nFROM scored\\nGROUP BY app_version\\nORDER BY app_version DESC\\nLIMIT 100\", \"truncate\": true}"},"source_record":{"timestamp":"2026-06-05T21:18:37.243Z","type":"response_item","payload":{"type":"function_call","name":"exec","namespace":"mcp__posthog","call_id":"[REDACTED:entropy]"}}}