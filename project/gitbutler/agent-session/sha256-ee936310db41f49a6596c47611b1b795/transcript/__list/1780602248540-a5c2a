com', 'stron@me.com', 'h1ghbre4k3r@dev.bre4k3r.de', 'caleb@gitbutler.com'\\n           )))\\n      AND message_blob LIKE '%would be overwritten by checkout%'\\n), totals AS (\\n    SELECT count() AS total_overwrite_events FROM clean\\n)\\nSELECT\\n    event,\\n    if(command IS NULL, '<no command>', command) AS command,\\n    if(action_name IS NULL, '<no action>', action_name) AS action_name,\\n    count() AS events,\\n    uniqExact(user_id) AS users,\\n    uniqExact(session_id) AS sessions,\\n    round(100.0 * events / any(total_overwrite_events), 2) AS share_of_overwrite_events_pct,\\n    min(timestamp) AS first_seen,\\n    max(timestamp) AS last_seen\\nFROM clean\\nCROSS JOIN totals\\nGROUP BY event, command, action_name\\nORDER BY events DESC\\nLIMIT 100\", \"truncate\": true}"},"source_record":{"timestamp":"2026-06-04T19:41:57.902Z","type":"response_item","payload":{"type":"function_call","name":"exec","namespace":"mcp__posthog","call_id":"[REDACTED:entropy]"}}}