{"source_key":"sha256-67ab078c7f660fb9364b7c83113ccb67","record_index":1184,"record_hash":"sha256:c5ee0f9016e8fd60d3a44662482e006e8a94096b8d5abb0662f96c6866b2ea78","timestamp":"2026-06-05T21:19:56.159Z","kind":"tool_call","source_event_kind":"codex:response_item:function_call","role":null,"text":null,"tool_name":"exec","tool_kind":"other","tool_input":{"command":"call execute-sql {\"query\":\"WITH version_bounds AS (\\n    SELECT\\n        toString(properties.appVersion) AS app_version,\\n        min(timestamp) AS start_ts\\n    FROM events\\n    WHERE timestamp >= now() - INTERVAL 45 DAY\\n      AND toString(properties.appVersion) IN ('0.20.0', '0.19.13')\\n    GROUP BY app_version\\n), elapsed AS (\\n    SELECT dateDiff('second', start_ts, now()) AS elapsed_seconds\\n    FROM version_bounds\\n    WHERE app_version = '0.20.0'\\n), base AS (\\n    SELECT\\n        toString(e.properties.appVersion) AS app_version,\\n        e.event AS event,\\n        e.timestamp AS timestamp,\\n        nullIf(toString(e.properties.$session_id), '') AS session_id,\\n        coalesce(nullIf(toString(e.person_id), '[REDACTED:entropy]'), e.distinct_id) AS user_id,\\n        lower(toString(e.person.properties.email)) AS email,\\n        nullIf(toString(e.properties.command), '') AS command,\\n        nullIf(toString(e.properties.error_title), '') AS error_title\\n    FROM events e\\n    INNER JOIN version_bounds b ON toString(e.properties.appVersion) = b.app_version\\n    CROSS JOIN elapsed\\n    WHERE e.timestamp >= b.start_ts\\n      AND e.timestamp < b.start_ts + INTERVAL elapsed.elapsed_seconds SECOND\\n      AND toString(e.properties.appVersion) IN ('0.20.0', '0.19.13')\\n      AND (e.event = 'query:error'\\n         OR e.event = 'toast:show_error'\\n         OR e.event ILIKE '% Failed'\\n         OR e.event ILIKE '% Failure'\\n         OR e.event ILIKE '% Error')\\n), clean AS (\\n    SELECT *\\n    FROM base\\n    WHERE email = ''\\n       OR (email NOT LIKE '%@gitbutler.com'\\n           AND email NOT IN (\\n               'donahue.ian@gmail.com', 'mtsgrd@gmail.com', 'leuschneranne@gmail.com', 'schacon@gmail.com',\\n               'kiril@videlov.com', 'nikita@galaiko.rocks', 'pawellaptew@gmail.com', 'nico@gitbutler.com',\\n               'hello@calebowens.com', 'stron@me.com', 'h1ghbre4k3r@dev.bre4k3r.de', 'caleb@gitbutler.com'\\n           ))\\n), bucketed AS (\\n    SELECT\\n        app_version,\\n        multiIf(\\n            event = 'query:error' AND command IS NOT NULL, command,\\n            event = 'query:error' AND error_title IS NOT NULL, concat('query:error: ', error_title),\\n            event\\n        ) AS bucket,\\n        user_id,\\n        session_id\\n    FROM clean\\n), agg AS (\\n    SELECT\\n        app_version,\\n        bucket,\\n        count() AS events,\\n        uniqExact(user_id) AS users,\\n        uniqExact(session_id) AS sessions\\n    FROM bucketed\\n    GROUP BY app_version, bucket\\n), totals AS (\\n    SELECT app_version, sum(events) AS total_error_events FROM agg GROUP BY app_version\\n), ranked_020 AS (\\n    SELECT bucket\\n    FROM agg\\n    WHERE app_version = '0.20.0'\\n    ORDER BY events DESC\\n    LIMIT 18\\n)\\nSELECT\\n    r.bucket,\\n    sumIf(a.events, a.app_version = '0.20.0') AS events_020,\\n    sumIf(a.users, a.app_version = '0.20.0') AS users_020,\\n    round(100.0 * events_020 / anyIf(t.total_error_events, t.app_version = '0.20.0'), 2) AS share_020_pct,\\n    sumIf(a.events, a.app_version = '0.19.13') AS events_01913,\\n    sumIf(a.users, a.app_version = '0.19.13') AS users_01913,\\n    round(100.0 * events_01913 / anyIf(t.total_error_events, t.app_version = '0.19.13'), 2) AS share_01913_pct,\\n    events_020 - events_01913 AS event_delta\\nFROM ranked_020 r\\nLEFT JOIN agg a ON a.bucket = r.bucket\\nLEFT JOIN totals t ON t.app_version = a.app_version\\nGROUP BY r.bucket\\nORDER BY events_020 DESC\\nLIMIT 100\", \"truncate\": true}"},"source_record":{"timestamp":"2026-06-05T21:19:56.159Z","type":"response_item","payload":{"type":"function_call","name":"exec","namespace":"mcp__posthog","call_id":"[REDACTED:entropy]"}}}