{"source_key":"sha256-67ab078c7f660fb9364b7c83113ccb67","record_index":1060,"record_hash":"sha256:cf399676399bfaee4c21b2e7bb88849e9421805cd2fb1fea099de537affb2eb7","timestamp":"2026-06-04T19:43:53.650Z","kind":"tool_call","source_event_kind":"codex:response_item:function_call","role":null,"text":null,"tool_name":"exec","tool_kind":"other","tool_input":{"command":"call execute-sql {\"query\":\"WITH base AS (\\n    SELECT\\n        event,\\n        timestamp,\\n        nullIf(toString(properties.$session_id), '') AS session_id,\\n        coalesce(nullIf(toString(person_id), '[REDACTED:entropy]'), distinct_id) AS user_id,\\n        lower(toString(person.properties.email)) AS email,\\n        if(toString(properties.appVersion) = '', '<none>', toString(properties.appVersion)) AS app_version,\\n        lower(concat(\\n            ' ', toString(properties.error),\\n            ' ', toString(properties.error_title),\\n            ' ', toString(properties.error_message),\\n            ' ', toString(properties.message),\\n            ' ', toString(properties.title),\\n            ' ', toString(issue_name),\\n            ' ', toString(issue_description)\\n        )) AS message_blob\\n    FROM events\\n    WHERE timestamp >= now() - INTERVAL 30 DAY\\n      AND event != 'toast:show_error'\\n      AND (event = 'query:error'\\n           OR lower(event) LIKE '% failed'\\n           OR lower(event) LIKE '% failure'\\n           OR lower(event) LIKE '% error'\\n           OR lower(event) LIKE '%_failed')\\n), clean AS (\\n    SELECT *\\n    FROM base\\n    WHERE email = ''\\n       OR (email NOT LIKE '%@gitbutler.com'\\n           AND email NOT IN (\\n               'donahue.ian@gmail.com', 'mtsgrd@gmail.com', 'leuschneranne@gmail.com', 'schacon@gmail.com',\\n               'kiril@videlov.com', 'nikita@galaiko.rocks', 'pawellaptew@gmail.com', 'nico@gitbutler.com',\\n               'hello@calebowens.com', 'stron@me.com', 'h1ghbre4k3r@dev.bre4k3r.de', 'caleb@gitbutler.com'\\n           ))\\n), scored AS (\\n    SELECT\\n        *,\\n        message_blob LIKE '%would be overwritten by checkout%' AS is_overwrite_checkout\\n    FROM clean\\n)\\nSELECT\\n    app_version,\\n    count() AS non_toast_error_events,\\n    uniqExact(user_id) AS non_toast_error_users,\\n    countIf(is_overwrite_checkout) AS overwrite_events,\\n    uniqExactIf(user_id, is_overwrite_checkout) AS overwrite_users,\\n    round(100.0 * overwrite_events / nullIf(non_toast_error_events, 0), 2) AS event_share_pct,\\n    round(100.0 * overwrite_users / nullIf(non_toast_error_users, 0), 2) AS user_share_pct\\nFROM scored\\nWHERE app_version IN ('0.20.0', '0.19.13', '0.19.10', '0.19.9', '0.19.12')\\nGROUP BY app_version\\nORDER BY app_version DESC\\nLIMIT 100\", \"truncate\": true}"},"source_record":{"timestamp":"2026-06-04T19:43:53.650Z","type":"response_item","payload":{"type":"function_call","name":"exec","namespace":"mcp__posthog","call_id":"[REDACTED:entropy]"}}}