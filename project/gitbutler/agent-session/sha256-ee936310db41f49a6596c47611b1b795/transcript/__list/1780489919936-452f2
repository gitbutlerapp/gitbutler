{"source_key":"sha256-67ab078c7f660fb9364b7c83113ccb67","record_index":153,"record_hash":"sha256:60dcb69dd237c89f2b21cebc03be3a613c3b0033399afb6c0b86040e8bd62ee8","timestamp":"2026-06-03T12:28:33.388Z","kind":"tool_call","source_event_kind":"codex:response_item:function_call","role":null,"text":null,"tool_name":"exec","tool_kind":"other","tool_input":{"command":"call execute-sql {\"query\":\"WITH base AS (SELECT properties.appVersion AS app_version, timestamp, coalesce(nullIf(toString(person_id), '[REDACTED:entropy]'), distinct_id) AS user_id, properties.command AS command, properties.error_title AS error_title, properties.error_code AS error_code, left(replaceRegexpAll(toString(properties.error_message), '[0-9a-f]{7,40}|/[A-Za-z0-9_./ -]+', '<redacted>'), 220) AS message_key FROM events WHERE timestamp >= now() - INTERVAL 30 DAY AND properties.appVersion IN ('0.20.0', '0.19.13') AND event = 'query:error') SELECT command, error_title, error_code, message_key, countIf(app_version = '0.20.0') AS v020_events, count(DISTINCT if(app_version = '0.20.0', user_id, NULL)) AS v020_users, countIf(app_version = '0.19.13') AS v019_events, count(DISTINCT if(app_version = '0.19.13', user_id, NULL)) AS v019_users, minIf(timestamp, app_version = '0.20.0') AS v020_first_seen, maxIf(timestamp, app_version = '0.20.0') AS v020_last_seen FROM base GROUP BY command, error_title, error_code, message_key HAVING v020_events > 0 ORDER BY v020_events DESC, v020_users DESC, v019_events ASC LIMIT 100\",\"truncate\":true}"},"source_record":{"timestamp":"2026-06-03T12:28:33.388Z","type":"response_item","payload":{"type":"function_call","name":"exec","namespace":"mcp__posthog","call_id":"[REDACTED:entropy]"}}}