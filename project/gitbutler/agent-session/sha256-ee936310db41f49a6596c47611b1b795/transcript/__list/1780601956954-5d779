{"source_key":"sha256-67ab078c7f660fb9364b7c83113ccb67","record_index":900,"record_hash":"sha256:a9bef4ad2b4325c78ea926c46ab670c01e36c34dd6393b5c26a1ba7571769e78","timestamp":"2026-06-04T19:38:02.072Z","kind":"tool_call","source_event_kind":"codex:response_item:function_call","role":null,"text":null,"tool_name":"exec","tool_kind":"other","tool_input":{"command":"call execute-sql {\"query\":\"WITH version_bounds AS (\\n    SELECT\\n        toString(properties.appVersion) AS app_version,\\n        min(timestamp) AS start_ts\\n    FROM events\\n    WHERE timestamp >= now() - INTERVAL 30 DAY\\n      AND toString(properties.appVersion) IN ('0.20.0', '0.19.13')\\n    GROUP BY app_version\\n), elapsed AS (\\n    SELECT dateDiff('second', start_ts, now()) AS elapsed_seconds\\n    FROM version_bounds\\n    WHERE app_version = '0.20.0'\\n), filtered AS (\\n    SELECT\\n        toString(e.properties.appVersion) AS app_version,\\n        e.event AS event,\\n        e.timestamp AS timestamp,\\n        nullIf(toString(e.properties.$session_id), '') AS session_id,\\n        coalesce(nullIf(toString(e.person_id), '[REDACTED:entropy]'), e.distinct_id) AS user_id,\\n        lower(toString(e.person.properties.email)) AS email,\\n        b.start_ts AS version_start\\n    FROM events e\\n    INNER JOIN version_bounds b ON toString(e.properties.appVersion) = b.app_version\\n    CROSS JOIN elapsed\\n    WHERE e.timestamp >= b.start_ts\\n      AND e.timestamp < b.start_ts + INTERVAL elapsed.elapsed_seconds SECOND\\n      AND toString(e.properties.appVersion) IN ('0.20.0', '0.19.13')\\n      AND e.event IN ('Create Virtual Branch From Branch Successful', 'Create Virtual Branch From Branch Failed')\\n), clean AS (\\n    SELECT *\\n    FROM filtered\\n    WHERE email = ''\\n       OR (email NOT LIKE '%@gitbutler.com'\\n           AND email NOT IN (\\n               'donahue.ian@gmail.com', 'mtsgrd@gmail.com', 'leuschneranne@gmail.com', 'schacon@gmail.com',\\n               'kiril@videlov.com', 'nikita@galaiko.rocks', 'pawellaptew@gmail.com', 'nico@gitbutler.com',\\n               'hello@calebowens.com', 'stron@me.com', 'h1ghbre4k3r@dev.bre4k3r.de', 'caleb@gitbutler.com'\\n           ))\\n)\\nSELECT\\n    app_version,\\n    min(version_start) AS version_start,\\n    min(timestamp) AS first_action_seen,\\n    max(timestamp) AS last_action_seen,\\n    countIf(event = 'Create Virtual Branch From Branch Successful') AS success_events,\\n    countIf(event = 'Create Virtual Branch From Branch Failed') AS failure_events,\\n    count() AS attempt_events,\\n    round(100.0 * failure_events / nullIf(attempt_events, 0), 2) AS failure_event_rate_pct,\\n    uniqExactIf(user_id, event = 'Create Virtual Branch From Branch Failed') AS failure_users,\\n    uniqExact(user_id) AS attempt_users,\\n    round(100.0 * failure_users / nullIf(attempt_users, 0), 2) AS failure_user_rate_pct\\nFROM clean\\nGROUP BY app_version\\nORDER BY app_version DESC\\nLIMIT 100\", \"truncate\": true}"},"source_record":{"timestamp":"2026-06-04T19:38:02.072Z","type":"response_item","payload":{"type":"function_call","name":"exec","namespace":"mcp__posthog","call_id":"[REDACTED:entropy]"}}}