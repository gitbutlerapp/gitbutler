{"source_key":"sha256-67ab078c7f660fb9364b7c83113ccb67","record_index":878,"record_hash":"sha256:9f2b2e2121b8671840c509f6eb24937cd0818c5360fb595edf12c02c4bfd7b5e","timestamp":"2026-06-04T19:37:20.581Z","kind":"tool_call","source_event_kind":"codex:response_item:function_call","role":null,"text":null,"tool_name":"exec","tool_kind":"other","tool_input":{"command":"call execute-sql {\"query\":\"WITH filtered AS (\\n    SELECT\\n        toString(properties.appVersion) AS app_version,\\n        event,\\n        timestamp,\\n        nullIf(toString(properties.$session_id), '') AS session_id,\\n        coalesce(nullIf(toString(person_id), '[REDACTED:entropy]'), distinct_id) AS user_id,\\n        lower(toString(person.properties.email)) AS email,\\n        nullIf(toString(properties.command), '') AS command,\\n        nullIf(toString(properties.error_title), '') AS error_title,\\n        nullIf(toString(properties.error_code), '') AS error_code,\\n        if(event = 'query:error', toString(properties.error_message), toString(properties.error)) AS raw_message\\n    FROM events\\n    WHERE timestamp >= now() - INTERVAL 30 DAY\\n      AND toString(properties.appVersion) IN ('0.20.0', '0.19.13')\\n      AND (event IN ('Create Virtual Branch From Branch Failed', 'Create Virtual Branch From Branch Successful')\\n           OR (event = 'query:error' AND toString(properties.command) = 'create_virtual_branch_from_branch'))\\n), clean AS (\\n    SELECT *\\n    FROM filtered\\n    WHERE email = ''\\n       OR (email NOT LIKE '%@gitbutler.com'\\n           AND email NOT IN (\\n               'donahue.ian@gmail.com', 'mtsgrd@gmail.com', 'leuschneranne@gmail.com', 'schacon@gmail.com',\\n               'kiril@videlov.com', 'nikita@galaiko.rocks', 'pawellaptew@gmail.com', 'nico@gitbutler.com',\\n               'hello@calebowens.com', 'stron@me.com', 'h1ghbre4k3r@dev.bre4k3r.de', 'caleb@gitbutler.com'\\n           ))\\n), normalized AS (\\n    SELECT\\n        app_version,\\n        event,\\n        if(command IS NULL, '<no command>', command) AS command,\\n        if(error_title IS NULL, if(event = 'Create Virtual Branch From Branch Failed', 'action failure', '<no title>'), error_title) AS title,\\n        if(error_code IS NULL, '<no code>', error_code) AS code,\\n        replaceRegexpAll(nullIf(raw_message, ''), '[0-9a-f]{7,40}', '<hex>') AS message_key,\\n        user_id,\\n        session_id\\n    FROM clean\\n    WHERE event != 'Create Virtual Branch From Branch Successful'\\n)\\nSELECT\\n    app_version,\\n    event,\\n    command,\\n    title,\\n    code,\\n    left(if(message_key IS NULL, '<no message>', message_key), 360) AS message,\\n    count() AS events,\\n    uniqExact(user_id) AS users,\\n    uniqExact(session_id) AS sessions\\nFROM normalized\\nGROUP BY app_version, event, command, title, code, message\\nORDER BY app_version DESC, events DESC\\nLIMIT 100\", \"truncate\": true}"},"source_record":{"timestamp":"2026-06-04T19:37:20.581Z","type":"response_item","payload":{"type":"function_call","name":"exec","namespace":"mcp__posthog","call_id":"[REDACTED:entropy]"}}}