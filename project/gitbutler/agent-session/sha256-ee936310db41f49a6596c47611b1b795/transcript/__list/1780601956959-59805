{"source_key":"sha256-67ab078c7f660fb9364b7c83113ccb67","record_index":911,"record_hash":"sha256:a5b1d3f36f500bb72076a82b8b6031a663dc428a419e6476f65cd2012afd1973","timestamp":"2026-06-04T19:38:32.660Z","kind":"tool_call","source_event_kind":"codex:response_item:function_call","role":null,"text":null,"tool_name":"exec","tool_kind":"other","tool_input":{"command":"call execute-sql {\"query\":\"WITH filtered AS (\\n    SELECT\\n        toString(properties.appVersion) AS app_version,\\n        timestamp,\\n        nullIf(toString(properties.$session_id), '') AS session_id,\\n        coalesce(nullIf(toString(person_id), '[REDACTED:entropy]'), distinct_id) AS user_id,\\n        lower(toString(person.properties.email)) AS email,\\n        toString(properties.error) AS raw_error\\n    FROM events\\n    WHERE timestamp >= now() - INTERVAL 30 DAY\\n      AND toString(properties.appVersion) IN ('0.20.0', '0.19.13')\\n      AND event = 'Create Virtual Branch From Branch Failed'\\n), clean AS (\\n    SELECT *\\n    FROM filtered\\n    WHERE email = ''\\n       OR (email NOT LIKE '%@gitbutler.com'\\n           AND email NOT IN (\\n               'donahue.ian@gmail.com', 'mtsgrd@gmail.com', 'leuschneranne@gmail.com', 'schacon@gmail.com',\\n               'kiril@videlov.com', 'nikita@galaiko.rocks', 'pawellaptew@gmail.com', 'nico@gitbutler.com',\\n               'hello@calebowens.com', 'stron@me.com', 'h1ghbre4k3r@dev.bre4k3r.de', 'caleb@gitbutler.com'\\n           ))\\n), bucketed AS (\\n    SELECT\\n        app_version,\\n        multiIf(\\n            raw_error LIKE '%GitButler workspace commit not found%', 'workspace commit not found',\\n            raw_error LIKE '%workspace commit isn%' OR raw_error LIKE '%workspace commit not%' OR raw_error LIKE '%Repo HEAD is unavailable%' OR raw_error LIKE '%Please checkout gitbutler/workspace%', 'workspace/ref state invalid',\\n            raw_error LIKE '%Uncommitted files would be overwritten by checkout%' OR raw_error LIKE '%Worktree changes would be overwritten by checkout%', 'checkout would overwrite local files',\\n            raw_error LIKE '%os error 32%' OR raw_error LIKE '%used by another process%' OR raw_error LIKE '%używany przez inny proces%', 'file locked / used by another process',\\n            raw_error LIKE '%Incorrect function. (os error 1)%', 'windows incorrect function',\\n            raw_error LIKE '%disjoint in the commit-graph%' OR raw_error LIKE '%find merge-base%', 'disjoint commit graph / merge-base',\\n            raw_error LIKE '%index is locked%', 'git index locked',\\n            raw_error LIKE '%Permission denied%' OR raw_error LIKE '%Access is denied%', 'permission denied',\\n            'other'\\n        ) AS bucket,\\n        user_id,\\n        session_id\\n    FROM clean\\n)\\nSELECT\\n    app_version,\\n    bucket,\\n    count() AS events,\\n    uniqExact(user_id) AS users,\\n    uniqExact(session_id) AS sessions\\nFROM bucketed\\nGROUP BY app_version, bucket\\nORDER BY app_version DESC, events DESC\\nLIMIT 100\", \"truncate\": true}"},"source_record":{"timestamp":"2026-06-04T19:38:32.660Z","type":"response_item","payload":{"type":"function_call","name":"exec","namespace":"mcp__posthog","call_id":"[REDACTED:entropy]"}}}