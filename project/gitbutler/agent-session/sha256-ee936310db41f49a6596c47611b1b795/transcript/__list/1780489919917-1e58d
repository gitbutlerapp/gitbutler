{"source_key":"sha256-67ab078c7f660fb9364b7c83113ccb67","record_index":111,"record_hash":"sha256:bae3b8c0e69d224e35fbbc39829f46f713f71ee545d9bc4cd2769d739cefda4d","timestamp":"2026-06-03T12:27:32.385Z","kind":"tool_call","source_event_kind":"codex:response_item:function_call","role":null,"text":null,"tool_name":"exec","tool_kind":"other","tool_input":{"command":"call execute-sql {\"query\":\"WITH base AS (SELECT properties.appVersion AS app_version, event, timestamp, uuid, $session_id, coalesce(nullIf(toString(person_id), '[REDACTED:entropy]'), distinct_id) AS user_id FROM events WHERE timestamp >= now() - INTERVAL 30 DAY AND properties.appVersion IN ('0.20.0', '0.19.13')), totals AS (SELECT app_version, min(timestamp) AS first_seen, max(timestamp) AS last_seen, count() AS total_events, count(DISTINCT user_id) AS active_users, count(DISTINCT nullIf($session_id, '')) AS active_sessions FROM base GROUP BY app_version), errors AS (SELECT app_version, count() AS error_events, count(DISTINCT user_id) AS error_users, count(DISTINCT nullIf($session_id, '')) AS error_sessions FROM base WHERE event = 'query:error' OR event = 'toast:show_error' OR event ILIKE '% Failed' OR event ILIKE '% Failure' OR event ILIKE '% Error' GROUP BY app_version) SELECT totals.app_version, first_seen, last_seen, active_users, active_sessions, total_events, coalesce(error_events, 0) AS error_events, coalesce(error_users, 0) AS error_users, coalesce(error_sessions, 0) AS error_sessions, round(coalesce(error_users,0) / active_users * 100, 2) AS error_user_rate_pct, round(coalesce(error_events,0) / total_events * 100, 2) AS error_event_rate_pct FROM totals LEFT JOIN errors ON totals.app_version = errors.app_version ORDER BY totals.app_version DESC LIMIT 100\",\"truncate\":true}"},"source_record":{"timestamp":"2026-06-03T12:27:32.385Z","type":"response_item","payload":{"type":"function_call","name":"exec","namespace":"mcp__posthog","call_id":"[REDACTED:entropy]"}}}