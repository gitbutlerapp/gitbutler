{"source_key":"sha256-67ab078c7f660fb9364b7c83113ccb67","record_index":133,"record_hash":"sha256:f30ac9cdac6278ecb4e9facc655980b53424b7496e8c847d1492096afee7e830","timestamp":"2026-06-03T12:28:08.816Z","kind":"tool_call","source_event_kind":"codex:response_item:function_call","role":null,"text":null,"tool_name":"exec","tool_kind":"other","tool_input":{"command":"call execute-sql {\"query\":\"WITH base AS (SELECT properties.appVersion AS app_version, event, timestamp, $session_id, coalesce(nullIf(toString(person_id), '[REDACTED:entropy]'), distinct_id) AS user_id FROM events WHERE timestamp >= now() - INTERVAL 30 DAY AND properties.appVersion IN ('0.20.0', '0.19.13') AND (event = 'query:error' OR event = 'toast:show_error' OR event ILIKE '% Failed' OR event ILIKE '% Failure' OR event ILIKE '% Error')) SELECT event, countIf(app_version = '0.20.0') AS v020_events, count(DISTINCT if(app_version = '0.20.0', user_id, NULL)) AS v020_users, countIf(app_version = '0.19.13') AS v019_events, count(DISTINCT if(app_version = '0.19.13', user_id, NULL)) AS v019_users, minIf(timestamp, app_version = '0.20.0') AS v020_first_seen, maxIf(timestamp, app_version = '0.20.0') AS v020_last_seen FROM base GROUP BY event HAVING v020_events > 0 OR v019_events > 0 ORDER BY v020_events DESC, v020_users DESC, v019_events DESC LIMIT 100\",\"truncate\":true}"},"source_record":{"timestamp":"2026-06-03T12:28:08.816Z","type":"response_item","payload":{"type":"function_call","name":"exec","namespace":"mcp__posthog","call_id":"[REDACTED:entropy]"}}}