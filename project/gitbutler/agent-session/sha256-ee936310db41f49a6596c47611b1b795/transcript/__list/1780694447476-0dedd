{"source_key":"sha256-67ab078c7f660fb9364b7c83113ccb67","record_index":1171,"record_hash":"sha256:7c28ca7d4174c5562555304903213c538cfefd1ce828970cbfbcc771460fd049","timestamp":"2026-06-05T21:19:27.503Z","kind":"tool_call","source_event_kind":"codex:response_item:function_call","role":null,"text":null,"tool_name":"exec","tool_kind":"other","tool_input":{"command":"call execute-sql {\"query\":\"WITH base AS (\\n    SELECT\\n        timestamp,\\n        nullIf(toString(properties.$session_id), '') AS session_id,\\n        coalesce(nullIf(toString(person_id), '[REDACTED:entropy]'), distinct_id) AS user_id,\\n        lower(toString(person.properties.email)) AS email,\\n        if(nullIf(toString(properties.command), '') IS NULL, '<no command>', toString(properties.command)) AS command,\\n        toString(properties.error) AS raw_error,\\n        toString(properties.appVersion) AS app_version\\n    FROM events\\n    WHERE timestamp >= now() - INTERVAL 45 DAY\\n      AND toString(properties.appVersion) = '0.20.0'\\n      AND event = 'undefined Failed'\\n), clean AS (\\n    SELECT *\\n    FROM base\\n    WHERE email = ''\\n       OR (email NOT LIKE '%@gitbutler.com'\\n           AND email NOT IN (\\n               'donahue.ian@gmail.com', 'mtsgrd@gmail.com', 'leuschneranne@gmail.com', 'schacon@gmail.com',\\n               'kiril@videlov.com', 'nikita@galaiko.rocks', 'pawellaptew@gmail.com', 'nico@gitbutler.com',\\n               'hello@calebowens.com', 'stron@me.com', 'h1ghbre4k3r@dev.bre4k3r.de', 'caleb@gitbutler.com'\\n           ))\\n), normalized AS (\\n    SELECT\\n        command,\\n        multiIf(\\n            raw_error LIKE '%GitButler workspace commit not found%', 'GitButler workspace commit not found',\\n            raw_error LIKE '%Failed to fetch remotes%', 'Failed to fetch remotes',\\n            raw_error LIKE '%Remote branch % not found%', 'Remote branch not found',\\n            raw_error LIKE '%Reference % not found%', 'Reference not found',\\n            raw_error LIKE '%already exists%', 'already exists',\\n            raw_error LIKE '%would be overwritten by checkout%', 'would be overwritten by checkout',\\n            raw_error LIKE '%does not appear to be a Git repository%' OR raw_error LIKE '%Could not read from remote repository%', 'remote not git repo / cannot read',\\n            raw_error LIKE '%Authentication failed%' OR raw_error LIKE '%credentials%' OR raw_error LIKE '%Permission denied%', 'auth/permission',\\n            raw_error LIKE '%network%' OR raw_error LIKE '%timed out%' OR raw_error LIKE '%Load failed%', 'network/load failed',\\n            left(replaceRegexpAll(raw_error, '[0-9a-f]{7,40}', '<hex>'), 240)\\n        ) AS message_key,\\n        user_id,\\n        session_id,\\n        timestamp\\n    FROM clean\\n)\\nSELECT\\n    command,\\n    message_key,\\n    count() AS events,\\n    uniqExact(user_id) AS users,\\n    uniqExact(session_id) AS sessions,\\n    min(timestamp) AS first_seen,\\n    max(timestamp) AS last_seen\\nFROM normalized\\nGROUP BY command, message_key\\nORDER BY events DESC\\nLIMIT 30\", \"truncate\": true}"},"source_record":{"timestamp":"2026-06-05T21:19:27.503Z","type":"response_item","payload":{"type":"function_call","name":"exec","namespace":"mcp__posthog","call_id":"[REDACTED:entropy]"}}}