rd file markers. With\n/// the F1 scrubber removed, these paths survive intact.\nfn apply_patch_paths(record: &ConversationRecord) -> Vec<String> {\n    let Some(input) = record.tool_input.as_ref() else {\n        return Vec::new();\n    };\n    let patch = input\n        .get(\"patch\")\n        .or_else(|| input.get(\"input\"))\n        .or_else(|| input.get(\"content\"))\n        .and_then(Value::as_str)\n        .map(str::to_owned)\n        .or_else(|| input.as_str().map(str::to_owned))\n        .unwrap_or_default();\n\n    let mut paths = Vec::new();\n    for line in patch.lines() {\n        let line = line.trim();\n        for marker in [\n            \"*** Update File: \",\n            \"*** Add File: \",\n            \"*** Delete File: \",\n            \"*** Move to: \",\n        ] {\n            if let Some(rest) = line.strip_prefix(marker) {\n                let path = rest.trim();\n                // Keep only repo-relative paths. Absolute or redacted paths are\n                // local-machine noise, not meaningful PR changes.\n                if !path.is_empty()\n                    && !path.starts_with('/')\n                    && !path.contains(\"[local path]\")\n                    && !path.contains('‹')\n                    && !path.contains(\"REDACTED\")\n                {\n                    paths.push(path.to_owned());\n                }\n            }\n","tool_name":null,"tool_input":null,"source_record":{"timestamp":"2026-05-25T07:43:13.862Z","type":"response_item","payload":{"type":"function_call_output","call_id":"[REDACTED:entropy]"}}}