{
	"name": "@gitbutler/lite",
	"productName": "gitbutler-lite",
	"homepage": "https://gitbutler.com",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"main": "dist/electron/main.js",
	"copyright": "Copyright 2026 GitButler Inc",
	"imports": {
		"#ui/*": "./ui/src/*",
		"#ui/hooks/*": "./ui/src/hooks/*",
		"#electron/*": "./electron/src/*"
	},
	"scripts": {
		"dev": "concurrently -k \"pnpm dev:ui\" \"pnpm dev:electron\"",
		"dev:ui": "vite dev --config ui/vite.config.ts --host 0.0.0.0",
		"dev:electron": "pnpm build:electron && wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron dist/electron/main.js",
		"build": "pnpm build:ui && pnpm build:electron",
		"build:ui": "vite build --config ui/vite.config.ts",
		"build:electron": "tsgo -p electron/tsconfig.json",
		"check": "tsgo -p ui/tsconfig.json --noEmit && tsgo -p electron/tsconfig.json --noEmit",
		"test": "vitest run --config ui/vitest.config.ts --passWithNoTests",
		"bundle": "pnpm build && electron-builder"
	},
	"build": {
		"appId": "com.gitbutler.lite",
		"publish": {
			"provider": "s3",
			"region": "us-east-1",
			"bucket": "releases.gitbutler.com",
			"path": "lite/${os}/${arch}",
			"channel": "${env.CHANNEL}"
		},
		"directories": {
			"output": "release"
		},
		"files": [
			"dist/ui/**/*",
			"dist/electron/**/*",
			"package.json"
		],
		"mac": {
			"target": [
				"dmg",
				"zip"
			],
			"hardenedRuntime": true,
			"gatekeeperAssess": false,
			"entitlements": "resources/entitlements.mac.plist",
			"entitlementsInherit": "resources/entitlements.mac.inherit.plist"
		},
		"linux": {
			"target": [
				"deb",
				"appimage"
			],
			"maintainer": "GitButler <gitbutler@gitbutler.com>"
		},
		"win": {
			"target": [
				"portable"
			],
			"publish": []
		},
		"deb": {
			"packageName": "gitbutler-lite",
			"artifactName": "${productName}-${version}-${arch}.${ext}",
			"depends": [
				"libnotify4",
				"libxtst6",
				"libnss3",
				"libxss1"
			]
		},
		"appImage": {
			"artifactName": "${productName}-${version}-${arch}.${ext}"
		}
	},
	"dependencies": {
		"@atlaskit/pragmatic-drag-and-drop": "^1.7.9",
		"@atlaskit/pragmatic-drag-and-drop-hitbox": "^1.1.0",
		"@base-ui/react": "^1.4.0",
		"@base-ui/utils": "^0.2.7",
		"@gitbutler/but-sdk": "workspace:*",
		"@pierre/diffs": "^1.1.3",
		"@reduxjs/toolkit": "catalog:redux",
		"@tanstack/react-query": "^5.90.21",
		"@tanstack/react-query-devtools": "^5.91.3",
		"@tanstack/react-router": "^1.167.4",
		"effect": "^3.20.0",
		"electron-devtools-installer": "^4.0.0",
		"electron-updater": "^6.8.4",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"react-redux": "^9.2.0",
		"react-resizable-panels": "^4.7.3"
	},
	"devDependencies": {
		"@tanstack/eslint-plugin-query": "^5.91.4",
		"@types/node": "^22.19.15",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@typescript/native-preview": "7.0.0-dev.20260311.1",
		"@vitejs/plugin-react": "^5.2.0",
		"babel-plugin-react-compiler": "^1.0.0",
		"concurrently": "^9.2.1",
		"cross-env": "^10.1.0",
		"electron": "^41.1.0",
		"electron-builder": "^26.9.0",
		"jsdom": "28.1.0",
		"vite": "catalog:",
		"vitest": "catalog:",
		"wait-on": "^9.0.4"
	}
}
