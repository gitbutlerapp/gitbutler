{
	"compilerOptions": {
		"target": "ES2022",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"strict": true,
		"noUncheckedIndexedAccess": true,
		"noImplicitReturns": true,
		"noEmit": true,
		"types": ["node"],
		"skipLibCheck": true
	},
	"include": ["playwright.config.ts", "src", "tests"]
}
